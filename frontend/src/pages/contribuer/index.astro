---
// Page contribuer — ajouter un produit
export const prerender = false
import Layout from '@/layouts/Layout.astro'
import ContributeForm from '@/components/ContributeForm.tsx'
import { getLocale, t } from '@/lib/i18n'

const localeCookie = Astro.cookies?.get('bayen_locale')?.value ?? null
const locale = getLocale(localeCookie)

// Récupérer le barcode depuis l'URL si présent (?barcode=xxx)
const barcode = Astro.url.searchParams.get('barcode') ?? ''
---

<Layout
  title={`${t('contribute.title', locale)} — Bayen`}
  description={t('contribute.subtitle', locale)}
  path="/contribuer"
>
  <main class="container mx-auto max-w-screen-lg px-4 py-6 pb-24">
    <div class="max-w-lg mx-auto">
      <div class="mb-6">
        <h1 class="text-2xl font-bold text-foreground">{t('contribute.title', locale)}</h1>
        <p class="text-sm text-muted-foreground mt-1">
          {t('contribute.subtitle', locale)}
        </p>
      </div>

      <ContributeForm initialBarcode={barcode} client:load />
    </div>
  </main>
</Layout>
