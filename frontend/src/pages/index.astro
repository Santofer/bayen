---
// Page d'accueil Bayen (SSR — données dynamiques)
export const prerender = false

import Layout from '@/layouts/Layout.astro'
import ProductCard from '@/components/ProductCard.tsx'
import BlogCarousel from '@/components/BlogCarousel.tsx'
import { getLocale, t } from '@/lib/i18n'
import type { Article } from '@/lib/types'

// Locale depuis le cookie SSR
const localeCookie = Astro.cookies?.get('bayen_locale')?.value ?? null
const locale = getLocale(localeCookie)

// Récupérer les produits récents et les stats depuis Directus
const DIRECTUS_URL = import.meta.env.PUBLIC_DIRECTUS_URL ?? 'https://api.bayen.ma'

let recentProducts: Record<string, unknown>[] = []
let recentArticles: Article[] = []
let totalProducts = 0
let totalScans = 0
let scansToday = 0

try {
  // Date du jour ISO pour filtrer les scans d'aujourd'hui
  const todayIso = new Date().toISOString().slice(0, 10)

  // Appels en parallèle pour réduire le TTFB
  const [productsRes, countRes, scansRes, scansTodayRes, articlesRes] = await Promise.all([
    fetch(
      // Uniquement les produits AVEC image : les images sont désormais
      // rapatriées dans Directus (backfill OFF), plus de prefetch fragile.
      `${DIRECTUS_URL}/items/products?filter[status][_eq]=published&filter[image_front][_nnull]=true&sort=-date_created&limit=6&fields=id,barcode,name_fr,brand,image_front,scan_score,score_label,nutriscore_grade,nova_group,additives,scan_count,data_source`,
      { signal: AbortSignal.timeout(5000) }
    ),
    fetch(
      `${DIRECTUS_URL}/items/products?filter[status][_eq]=published&aggregate[count]=id`,
      { signal: AbortSignal.timeout(3000) }
    ),
    fetch(
      `${DIRECTUS_URL}/items/scans?aggregate[count]=id`,
      { signal: AbortSignal.timeout(3000) }
    ),
    fetch(
      `${DIRECTUS_URL}/items/scans?filter[date_created][_gte]=${todayIso}&aggregate[count]=id`,
      { signal: AbortSignal.timeout(3000) }
    ),
    fetch(
      `${DIRECTUS_URL}/items/articles?filter[status][_eq]=published&sort=-date_published&limit=8&fields=id,slug,title_fr,title_ar,excerpt_fr,excerpt_ar,cover_image,category,reading_time_min,date_published,date_created`,
      { signal: AbortSignal.timeout(4000) }
    ),
  ])

  if (productsRes.ok) {
    const data = await productsRes.json()
    recentProducts = data.data ?? []
  }
  if (countRes.ok) {
    const countData = await countRes.json()
    totalProducts = countData.data?.[0]?.count?.id ?? 0
  }
  if (scansRes.ok) {
    const scansData = await scansRes.json()
    totalScans = scansData.data?.[0]?.count?.id ?? 0
  }
  if (scansTodayRes.ok) {
    const todayData = await scansTodayRes.json()
    scansToday = todayData.data?.[0]?.count?.id ?? 0
  }
  if (articlesRes.ok) {
    const articlesData = await articlesRes.json()
    recentArticles = (articlesData.data ?? []) as Article[]
  }
} catch {
  // Pas de données — la page s'affiche quand même
}

// NOTE : plus de prefetch OFF côté SSR — c'était fragile (rate limit OFF,
// timeout 2,5 s × 6 produits sur CHAQUE page vue → images intermittentes
// + TTFB dégradé). Les images sont maintenant importées dans Directus une
// fois pour toutes (script de backfill) et servies via /assets avec
// transformations. Le filtre image_front _nnull garantit des cartes pleines.

// Plus de fake minimum : on affiche les vrais chiffres.
// Si la base est vide (ex: environnement staging), on affiche 0.
---

<Layout
  title="Bayen — Notation des produits alimentaires au Maroc"
  description="Scanne le code-barres de tes produits alimentaires et obtiens le Nutri-Score, les additifs et un score santé 0-100. 100% gratuit, sans pub. Conçu pour le Maroc."
  path="/"
>
  <main class="pb-24 md:pb-8">

    <!-- Héro carousel — vitrine des fonctionnalités -->
    <section class="container mx-auto max-w-screen-lg px-4 pt-4 sm:pt-6">
      <div
        id="hero-carousel"
        class="relative overflow-hidden rounded-[1.75rem] shadow-lift"
        data-count="5"
        style="aspect-ratio: 16 / 10"
      >
        <div id="hero-track" class="flex h-full transition-transform duration-700 ease-out" style="width: 500%">
          {[
            {
              img: '/hero/scan.jpg', href: '/scan', badge: t('home.slideScanBadge', locale),
              title1: t('home.hero1', locale), title2: t('home.hero2', locale),
              desc: t('home.subtitle', locale), cta: t('home.scanBtn', locale), h1: true,
            },
            {
              img: '/hero/repas.jpg', href: '/analyser-repas', badge: t('home.slideCoachBadge', locale),
              title1: t('home.slideCoachTitle', locale), desc: t('home.slideCoachDesc', locale), cta: t('home.slideCoachCta', locale),
            },
            {
              img: '/hero/panier.jpg', href: '/panier', badge: t('home.slideCartBadge', locale),
              title1: t('home.slideCartTitle', locale), desc: t('home.slideCartDesc', locale), cta: t('home.slideCartCta', locale),
            },
            {
              img: '/hero/comparer.jpg', href: '/comparer', badge: t('home.slideCompareBadge', locale),
              title1: t('home.slideCompareTitle', locale), desc: t('home.slideCompareDesc', locale), cta: t('home.slideCompareCta', locale),
            },
            {
              img: '/hero/partenaires.jpg', href: '/partenaires', badge: t('home.slidePartnerBadge', locale),
              title1: t('home.slidePartnerTitle', locale), desc: t('home.slidePartnerDesc', locale), cta: t('home.slidePartnerCta', locale),
            },
          ].map((s) => (
            <div class="relative h-full" style="width: 20%">
              <img src={s.img} alt="" loading="eager" class="absolute inset-0 h-full w-full object-cover" />
              <div class="absolute inset-0" style="background: linear-gradient(90deg, hsl(100 32% 9% / 0.86) 0%, hsl(100 30% 12% / 0.62) 42%, hsl(100 28% 16% / 0.12) 78%, transparent 100%)"></div>
              <div class="absolute inset-0 flex flex-col justify-center gap-3 sm:gap-4 p-6 sm:p-10 lg:p-14 max-w-[88%] sm:max-w-[72%]">
                <span class="inline-flex w-fit items-center gap-2 rounded-full bg-[#b1cf3a] px-3 py-1.5 text-[0.7rem] sm:text-xs font-bold uppercase tracking-wide text-[#233317]">
                  {s.badge}
                </span>
                {s.h1 ? (
                  <h1 class="font-display font-extrabold leading-[0.95] text-[#f0f2d2] text-[2rem] sm:text-5xl lg:text-6xl">
                    <span class="block">{s.title1}</span>
                    <span class="block text-[#b1cf3a]">{s.title2}</span>
                  </h1>
                ) : (
                  <h2 class="font-display font-extrabold leading-[1.02] text-[#f0f2d2] text-[1.7rem] sm:text-4xl lg:text-5xl">
                    {s.title1}
                  </h2>
                )}
                <p class="text-[#f0f2d2]/85 text-sm sm:text-base max-w-md leading-relaxed line-clamp-3">
                  {s.desc}
                </p>
                <a
                  href={s.href}
                  class="mt-1 inline-flex w-fit items-center gap-2 rounded-full bg-[#b1cf3a] px-6 py-3 text-sm sm:text-base font-bold text-[#233317] hover:bg-[#c4de5a] shadow-lg transition-colors"
                >
                  {s.cta}
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
                  </svg>
                </a>
              </div>
            </div>
          ))}
        </div>

        <!-- Dots -->
        <div id="hero-dots" class="absolute bottom-3.5 left-1/2 -translate-x-1/2 flex gap-2 z-10">
          {[0, 1, 2, 3, 4].map((i) => (
            <button
              type="button"
              data-idx={i}
              aria-label={`Fonctionnalité ${i + 1}`}
              class="h-2 rounded-full bg-white/50 transition-all duration-300"
              style={i === 0 ? 'width: 22px; background: #b1cf3a' : 'width: 8px'}
            ></button>
          ))}
        </div>
      </div>
    </section>

    <script is:inline>
      (() => {
        const car = document.getElementById('hero-carousel')
        const track = document.getElementById('hero-track')
        const dots = [...document.querySelectorAll('#hero-dots button')]
        if (!car || !track) return
        const n = parseInt(car.dataset.count || '5', 10)
        const rtl = document.documentElement.dir === 'rtl'
        let i = 0
        let timer = null
        const render = () => {
          track.style.transform = `translateX(${(rtl ? 1 : -1) * i * (100 / n)}%)`
          dots.forEach((d, k) => {
            const on = k === i
            d.style.width = on ? '22px' : '8px'
            d.style.background = on ? '#b1cf3a' : 'rgba(255,255,255,0.5)'
          })
        }
        const go = (k) => { i = (k + n) % n; render() }
        const start = () => { stop(); timer = setInterval(() => go(i + 1), 5000) }
        const stop = () => { if (timer) clearInterval(timer) }
        dots.forEach((d) => d.addEventListener('click', () => { go(parseInt(d.dataset.idx, 10)); start() }))
        car.addEventListener('mouseenter', stop)
        car.addEventListener('mouseleave', start)
        if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) start()
      })()
    </script>

    <!-- Stats -->
    <section class="container mx-auto max-w-screen-lg px-4 py-2">
      <div class="grid grid-cols-3 gap-3 sm:gap-6">
        <div class="rounded-2xl border bg-card p-4 text-center shadow-[var(--shadow-card)]">
          <p class="text-2xl sm:text-3xl font-bold text-primary">
            {totalProducts.toLocaleString('fr-FR')}
          </p>
          <p class="text-xs sm:text-sm text-muted-foreground mt-1">{t('home.products', locale)}</p>
        </div>
        <div class="rounded-2xl border bg-card p-4 text-center shadow-[var(--shadow-card)]">
          <p class="text-2xl sm:text-3xl font-bold text-primary">
            {totalScans.toLocaleString('fr-FR')}
          </p>
          <p class="text-xs sm:text-sm text-muted-foreground mt-1">{t('home.scans', locale)}</p>
        </div>
        <div class="rounded-2xl border bg-card p-4 text-center shadow-[var(--shadow-card)]">
          <p class="text-2xl sm:text-3xl font-bold text-primary">
            {scansToday > 0 ? `+${scansToday.toLocaleString('fr-FR')}` : '100%'}
          </p>
          <p class="text-xs sm:text-sm text-muted-foreground mt-1">
            {scansToday > 0 ? t('home.scansToday', locale) : t('home.free', locale)}
          </p>
        </div>
      </div>
    </section>

    <!-- CTA : Analyser un repas (feature VLM) -->
    <section class="container mx-auto max-w-screen-lg px-4 pt-6 pb-2">
      <a href="/analyser-repas" class="group flex items-center gap-4 rounded-2xl border border-primary/20 bg-gradient-to-br from-primary/10 via-primary/5 to-transparent hover:border-primary/40 hover:shadow-md transition-all p-4 sm:p-6">
        <div class="w-12 h-12 sm:w-14 sm:h-14 rounded-xl bg-primary/10 flex items-center justify-center flex-shrink-0">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary sm:w-7 sm:h-7">
            <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z" />
            <circle cx="12" cy="13" r="4" />
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <h3 class="font-bold text-foreground text-base sm:text-lg">{t('meal.pageTitle', locale)}</h3>
          <p class="text-xs sm:text-sm text-muted-foreground mt-0.5 line-clamp-2">
            {t('meal.pageSubtitle', locale)}
          </p>
        </div>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary flex-shrink-0 group-hover:translate-x-1 transition-transform">
          <polyline points="9 18 15 12 9 6" />
        </svg>
      </a>
    </section>

    <!-- Comment ça marche -->
    <section class="reveal container mx-auto max-w-screen-lg px-4 py-12">
      <h2 class="font-bold text-foreground text-center mb-8">{t('home.howTitle', locale)}</h2>
      <div class="grid sm:grid-cols-3 gap-6">
        <div class="text-center">
          <div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-3">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
              <path d="M3 7V5a2 2 0 012-2h2" />
              <path d="M17 3h2a2 2 0 012 2v2" />
              <path d="M21 17v2a2 2 0 01-2 2h-2" />
              <path d="M7 21H5a2 2 0 01-2-2v-2" />
              <line x1="7" y1="12" x2="17" y2="12" />
            </svg>
          </div>
          <h3 class="font-semibold text-foreground">1. {t('home.step1', locale)}</h3>
          <p class="text-sm text-muted-foreground mt-1">
            {t('home.step1Desc', locale)}
          </p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-3">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
              <circle cx="12" cy="12" r="10" />
              <path d="M8 12l3 3 5-5" />
            </svg>
          </div>
          <h3 class="font-semibold text-foreground">2. {t('home.step2', locale)}</h3>
          <p class="text-sm text-muted-foreground mt-1">
            {t('home.step2Desc', locale)}
          </p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-3">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
              <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z" />
            </svg>
          </div>
          <h3 class="font-semibold text-foreground">3. {t('home.step3', locale)}</h3>
          <p class="text-sm text-muted-foreground mt-1">
            {t('home.step3Desc', locale)}
          </p>
        </div>
      </div>
    </section>

    <!-- Articles récents (blog) -->
    {recentArticles.length > 0 && (
      <section class="reveal container mx-auto max-w-screen-lg px-4 pb-12">
        <div class="flex items-center justify-between mb-4">
          <h2 class="font-bold text-foreground">{t('blog.recentTitle', locale)}</h2>
          <a href="/blog" class="text-sm text-primary hover:underline">{t('blog.seeAll', locale)}</a>
        </div>
        <BlogCarousel articles={recentArticles} locale={locale} client:idle />
      </section>
    )}

    <!-- Produits populaires -->
    {recentProducts.length > 0 && (
      <section class="reveal container mx-auto max-w-screen-lg px-4 pb-12">
        <div class="flex items-center justify-between mb-4">
          <h2 class="font-bold text-foreground">{t('home.popular', locale)}</h2>
          <a href="/recherche" class="text-sm text-primary hover:underline">{t('home.seeAll', locale)}</a>
        </div>
        <div class="grid sm:grid-cols-2 gap-3">
          {recentProducts.map((product) => (
            <ProductCard product={product as any} />
          ))}
        </div>
      </section>
    )}

    <!-- CTA Contribution -->
    <section class="reveal container mx-auto max-w-screen-lg px-4 pb-8">
      <div class="rounded-xl bg-card border border-border p-6 sm:p-8 text-center">
        <h2 class="font-bold text-foreground">{t('home.missingTitle', locale)}</h2>
        <p class="text-sm text-muted-foreground mt-2 max-w-md mx-auto">
          {t('home.missingDesc', locale)}
        </p>
        <a
          href="/contribuer"
          class="inline-flex items-center gap-2 mt-4 px-6 py-2.5 rounded-md bg-primary text-primary-foreground text-sm font-medium hover:bg-primary/90"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19" />
            <line x1="5" y1="12" x2="19" y2="12" />
          </svg>
          {t('home.addProduct', locale)}
        </a>
      </div>
    </section>

    <!-- Liens rapides -->
    <section class="reveal container mx-auto max-w-screen-lg px-4 pb-12">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        <a href="/importer" class="flex flex-col items-center gap-2 card-lift rounded-2xl border bg-card p-4 text-center">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
            <polyline points="7 10 12 15 17 10" />
            <line x1="12" y1="15" x2="12" y2="3" />
          </svg>
          <span class="text-xs font-medium">{t('home.import', locale)}</span>
        </a>
        <a href="/classement" class="flex flex-col items-center gap-2 card-lift rounded-2xl border bg-card p-4 text-center">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
          <span class="text-xs font-medium">{t('home.ranking', locale)}</span>
        </a>
        <a href="/categories" class="flex flex-col items-center gap-2 card-lift rounded-2xl border bg-card p-4 text-center">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
            <rect x="3" y="3" width="7" height="7" />
            <rect x="14" y="3" width="7" height="7" />
            <rect x="14" y="14" width="7" height="7" />
            <rect x="3" y="14" width="7" height="7" />
          </svg>
          <span class="text-xs font-medium">{t('search.categories', locale)}</span>
        </a>
        <a href="/additifs" class="flex flex-col items-center gap-2 card-lift rounded-2xl border bg-card p-4 text-center">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
            <path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2" />
            <path d="M8.5 2h7" />
          </svg>
          <span class="text-xs font-medium">{t('nav.additives', locale)}</span>
        </a>
      </div>
    </section>

  </main>
</Layout>
