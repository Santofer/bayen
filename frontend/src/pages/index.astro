---
// Page d'accueil Bayen (SSR — données dynamiques)
export const prerender = false

import Layout from '@/layouts/Layout.astro'
import ProductCard from '@/components/ProductCard.tsx'
import BlogCarousel from '@/components/BlogCarousel.tsx'
import { getLocale, t } from '@/lib/i18n'
import type { Article } from '@/lib/types'

// Locale depuis le cookie SSR
const localeCookie = Astro.cookies?.get('bayen_locale')?.value ?? null
const locale = getLocale(localeCookie)

// Récupérer les produits récents et les stats depuis Directus
const DIRECTUS_URL = import.meta.env.PUBLIC_DIRECTUS_URL ?? 'https://api.bayen.ma'

let recentProducts: Record<string, unknown>[] = []
let recentArticles: Article[] = []
let totalProducts = 0
let totalScans = 0
let scansToday = 0
let totalCategories = 12

try {
  // Date du jour ISO pour filtrer les scans d'aujourd'hui
  const todayIso = new Date().toISOString().slice(0, 10)

  // Appels en parallèle pour réduire le TTFB
  const [productsRes, countRes, scansRes, scansTodayRes, articlesRes, catCountRes] = await Promise.all([
    fetch(
      // Uniquement les produits AVEC image : les images sont désormais
      // rapatriées dans Directus (backfill OFF), plus de prefetch fragile.
      `${DIRECTUS_URL}/items/products?filter[status][_eq]=published&filter[image_front][_nnull]=true&sort=-date_created&limit=6&fields=id,barcode,name_fr,brand,image_front,scan_score,score_label,nutriscore_grade,nova_group,additives,scan_count,data_source`,
      { signal: AbortSignal.timeout(5000) }
    ),
    fetch(
      `${DIRECTUS_URL}/items/products?filter[status][_eq]=published&aggregate[count]=id`,
      { signal: AbortSignal.timeout(3000) }
    ),
    fetch(
      `${DIRECTUS_URL}/items/scans?aggregate[count]=id`,
      { signal: AbortSignal.timeout(3000) }
    ),
    fetch(
      `${DIRECTUS_URL}/items/scans?filter[date_created][_gte]=${todayIso}&aggregate[count]=id`,
      { signal: AbortSignal.timeout(3000) }
    ),
    fetch(
      `${DIRECTUS_URL}/items/articles?filter[status][_eq]=published&sort=-date_published&limit=8&fields=id,slug,title_fr,title_ar,excerpt_fr,excerpt_ar,cover_image,category,reading_time_min,date_published,date_created`,
      { signal: AbortSignal.timeout(4000) }
    ),
    fetch(
      `${DIRECTUS_URL}/items/categories?aggregate[count]=id`,
      { signal: AbortSignal.timeout(3000) }
    ),
  ])

  if (productsRes.ok) {
    const data = await productsRes.json()
    recentProducts = data.data ?? []
  }
  if (countRes.ok) {
    const countData = await countRes.json()
    totalProducts = countData.data?.[0]?.count?.id ?? 0
  }
  if (scansRes.ok) {
    const scansData = await scansRes.json()
    totalScans = scansData.data?.[0]?.count?.id ?? 0
  }
  if (scansTodayRes.ok) {
    const todayData = await scansTodayRes.json()
    scansToday = todayData.data?.[0]?.count?.id ?? 0
  }
  if (articlesRes.ok) {
    const articlesData = await articlesRes.json()
    recentArticles = (articlesData.data ?? []) as Article[]
  }
  if (catCountRes.ok) {
    const catData = await catCountRes.json()
    totalCategories = Number(catData.data?.[0]?.count?.id ?? 12)
  }
} catch {
  // Pas de données — la page s'affiche quand même
}

// NOTE : plus de prefetch OFF côté SSR — c'était fragile (rate limit OFF,
// timeout 2,5 s × 6 produits sur CHAQUE page vue → images intermittentes
// + TTFB dégradé). Les images sont maintenant importées dans Directus une
// fois pour toutes (script de backfill) et servies via /assets avec
// transformations. Le filtre image_front _nnull garantit des cartes pleines.

// Plus de fake minimum : on affiche les vrais chiffres.
// Si la base est vide (ex: environnement staging), on affiche 0.

// ── Slides du hero carousel (une par fonctionnalité — maquette v2) ──
const ICONS: Record<string, string> = {
  scan: '<path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/><line x1="7" y1="12" x2="17" y2="12"/>',
  spark: '<path d="m12 3-1.9 5.8a2 2 0 0 1-1.3 1.3L3 12l5.8 1.9a2 2 0 0 1 1.3 1.3L12 21l1.9-5.8a2 2 0 0 1 1.3-1.3L21 12l-5.8-1.9a2 2 0 0 1-1.3-1.3Z"/>',
  basket: '<path d="m5 11 4-7"/><path d="m19 11-4-7"/><path d="M2 11h20"/><path d="m3.5 11 1.6 7.4a2 2 0 0 0 2 1.6h9.8a2 2 0 0 0 2-1.6l1.7-7.4"/><path d="m9 11 1 9"/><path d="m15 11-1 9"/>',
  scale: '<path d="m16 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="m2 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="M7 21h10"/><path d="M12 3v18"/><path d="M3 7h2c2 0 5-1 7-2 2 1 5 2 7 2h2"/>',
  users: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
}

const slides = [
  {
    img: '/hero/scan.jpg', href: '/scan', icon: ICONS.scan, isH1: true,
    badge: t('home.slideScanBadge', locale),
    title: t('home.hero1', locale), em: t('home.hero2', locale),
    desc: t('home.slideScanDesc', locale), cta: t('home.scanBtn', locale),
  },
  {
    img: '/hero/repas.jpg', href: '/analyser-repas', icon: ICONS.spark, isH1: false,
    badge: t('home.slideCoachBadge', locale),
    title: t('home.slideCoachTitle', locale), em: t('home.slideCoachEm', locale),
    desc: t('home.slideCoachDesc', locale), cta: t('home.slideCoachCta', locale),
  },
  {
    img: '/hero/panier.jpg', href: '/panier', icon: ICONS.basket, isH1: false,
    badge: t('home.slideCartBadge', locale),
    title: t('home.slideCartTitle', locale), em: t('home.slideCartEm', locale),
    desc: t('home.slideCartDesc', locale), cta: t('home.slideCartCta', locale),
  },
  {
    img: '/hero/comparer.jpg', href: '/comparer', icon: ICONS.scale, isH1: false,
    badge: t('home.slideCompareBadge', locale),
    title: t('home.slideCompareTitle', locale), em: t('home.slideCompareEm', locale),
    desc: t('home.slideCompareDesc', locale), cta: t('home.slideCompareCta', locale),
  },
  {
    img: '/hero/partenaires.jpg', href: '/partenaires', icon: ICONS.users, isH1: false,
    badge: t('home.slidePartnerBadge', locale),
    title: t('home.slidePartnerTitle', locale), em: t('home.slidePartnerEm', locale),
    desc: t('home.slidePartnerDesc', locale), cta: t('home.slidePartnerCta', locale),
  },
]
---

<Layout
  title="Bayen — Notation des produits alimentaires au Maroc"
  description="Scanne le code-barres de tes produits alimentaires et obtiens le Nutri-Score, les additifs et un score santé 0-100. 100% gratuit, sans pub. Conçu pour le Maroc."
  path="/"
>
  <main class="pb-24 md:pb-8">

    <!-- HERO CAROUSEL — vitrine des fonctionnalités (maquette v2, CSS .hero-* dans globals.css) -->
    <header class="hero-v2">
      <div id="hero-slides" class="hero-slides">
        {slides.map((s) => (
          <div class="hero-slide">
            <img src={s.img} alt="" loading="eager" />
            <div class="hero-scrim">
              <span class="hero-kicker">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon} />
                {s.badge}
              </span>
              {s.isH1 ? (
                <h1 class="hero-title">{s.title} <em>{s.em}</em></h1>
              ) : (
                <h2 class="hero-title">{s.title} <em>{s.em}</em></h2>
              )}
              <p class="hero-desc">{s.desc}</p>
              <a class="hero-go" href={s.href}>{s.cta} <span aria-hidden="true">→</span></a>
            </div>
          </div>
        ))}
      </div>

      <!-- Dots — sous le carousel (maquette) -->
      <div id="hero-dots" class="hero-dots">
        {slides.map((_, i) => (
          <button type="button" class:list={[{ on: i === 0 }]} aria-label={`Fonctionnalité ${i + 1}`}></button>
        ))}
      </div>
    </header>

    <script is:inline>
      // Carousel : autoplay doux + dots synchronisés + pause au survol (maquette v2)
      (() => {
        const slides = document.getElementById('hero-slides')
        const dotsEl = document.getElementById('hero-dots')
        if (!slides || !dotsEl) return
        const dots = [...dotsEl.children]
        const n = slides.children.length
        let i = 0
        let timer = null
        const paint = () => dots.forEach((d, k) => d.classList.toggle('on', k === i))
        const go = (k) => {
          i = (k + n) % n
          slides.scrollTo({ left: slides.clientWidth * i * (document.documentElement.dir === 'rtl' ? -1 : 1), behavior: 'smooth' })
          paint()
        }
        const auto = () => { stop(); timer = setInterval(() => go(i + 1), 4500) }
        const stop = () => { if (timer) clearInterval(timer) }
        dots.forEach((d, k) => d.addEventListener('click', () => { go(k); auto() }))
        slides.addEventListener('pointerenter', stop)
        slides.addEventListener('pointerleave', auto)
        slides.addEventListener('scroll', () => {
          const k = Math.round(Math.abs(slides.scrollLeft) / slides.clientWidth)
          if (k !== i && k < n) { i = k; paint() }
        }, { passive: true })
        if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) auto()
      })()
    </script>

    <!-- Stats bandeau (maquette v2) -->
    <section class="stats-v2">
      <div class="stat-v2">
        <div class="n">{totalProducts.toLocaleString('fr-FR')}</div>
        <div class="l">{t('home.statProducts', locale)}</div>
      </div>
      <a href="/categories" class="stat-v2">
        <div class="n">{totalCategories}</div>
        <div class="l">{t('home.statCategories', locale)}</div>
      </a>
      <div class="stat-v2">
        <div class="n">100%</div>
        <div class="l">{t('home.statFree', locale)}</div>
      </div>
    </section>

    <!-- CTA : Analyser un repas (feature VLM) -->
    <section class="section-v2 pt-6 pb-2">
      <a href="/analyser-repas" class="group flex items-center gap-4 rounded-2xl border border-primary/20 bg-gradient-to-br from-primary/10 via-primary/5 to-transparent hover:border-primary/40 hover:shadow-md transition-all p-4 sm:p-6">
        <div class="w-12 h-12 sm:w-14 sm:h-14 rounded-xl bg-primary/10 flex items-center justify-center flex-shrink-0">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary sm:w-7 sm:h-7">
            <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z" />
            <circle cx="12" cy="13" r="4" />
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <h3 class="font-bold text-foreground text-base sm:text-lg">{t('meal.pageTitle', locale)}</h3>
          <p class="text-xs sm:text-sm text-muted-foreground mt-0.5 line-clamp-2">
            {t('meal.pageSubtitle', locale)}
          </p>
        </div>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary flex-shrink-0 group-hover:translate-x-1 transition-transform">
          <polyline points="9 18 15 12 9 6" />
        </svg>
      </a>
    </section>

    <!-- Comment ça marche -->
    <section class="reveal section-v2 py-12">
      <h2 class="font-bold text-foreground text-center mb-8">{t('home.howTitle', locale)}</h2>
      <div class="grid sm:grid-cols-3 gap-6">
        <div class="text-center">
          <div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-3">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
              <path d="M3 7V5a2 2 0 012-2h2" />
              <path d="M17 3h2a2 2 0 012 2v2" />
              <path d="M21 17v2a2 2 0 01-2 2h-2" />
              <path d="M7 21H5a2 2 0 01-2-2v-2" />
              <line x1="7" y1="12" x2="17" y2="12" />
            </svg>
          </div>
          <h3 class="font-semibold text-foreground">1. {t('home.step1', locale)}</h3>
          <p class="text-sm text-muted-foreground mt-1">
            {t('home.step1Desc', locale)}
          </p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-3">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
              <circle cx="12" cy="12" r="10" />
              <path d="M8 12l3 3 5-5" />
            </svg>
          </div>
          <h3 class="font-semibold text-foreground">2. {t('home.step2', locale)}</h3>
          <p class="text-sm text-muted-foreground mt-1">
            {t('home.step2Desc', locale)}
          </p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-3">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
              <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z" />
            </svg>
          </div>
          <h3 class="font-semibold text-foreground">3. {t('home.step3', locale)}</h3>
          <p class="text-sm text-muted-foreground mt-1">
            {t('home.step3Desc', locale)}
          </p>
        </div>
      </div>
    </section>

    <!-- Articles récents (blog) -->
    {recentArticles.length > 0 && (
      <section class="reveal section-v2 pb-12">
        <div class="sec-head-v2">
          <h2>{t('blog.recentTitle', locale)}</h2>
          <a href="/blog">{t('blog.seeAll', locale)} →</a>
        </div>
        <BlogCarousel articles={recentArticles} locale={locale} client:idle />
      </section>
    )}

    <!-- Produits populaires -->
    {recentProducts.length > 0 && (
      <section class="reveal section-v2 pb-12">
        <div class="sec-head-v2">
          <h2>{t('home.latestProducts', locale)}</h2>
          <a href="/recherche">{t('home.seeAll', locale)} →</a>
        </div>
        <div class="grid sm:grid-cols-2 gap-3">
          {recentProducts.map((product) => (
            <ProductCard product={product as any} />
          ))}
        </div>
      </section>
    )}

    <!-- CTA Contribution -->
    <section class="reveal section-v2 pb-8">
      <div class="rounded-xl bg-card border border-border p-6 sm:p-8 text-center">
        <h2 class="font-bold text-foreground">{t('home.missingTitle', locale)}</h2>
        <p class="text-sm text-muted-foreground mt-2 max-w-md mx-auto">
          {t('home.missingDesc', locale)}
        </p>
        <a
          href="/contribuer"
          class="inline-flex items-center gap-2 mt-4 px-6 py-2.5 rounded-md bg-primary text-primary-foreground text-sm font-medium hover:bg-primary/90"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19" />
            <line x1="5" y1="12" x2="19" y2="12" />
          </svg>
          {t('home.addProduct', locale)}
        </a>
      </div>
    </section>

    <!-- Liens rapides -->
    <section class="reveal section-v2 pb-12">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        <a href="/importer" class="flex flex-col items-center gap-2 card-lift rounded-2xl border bg-card p-4 text-center">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
            <polyline points="7 10 12 15 17 10" />
            <line x1="12" y1="15" x2="12" y2="3" />
          </svg>
          <span class="text-xs font-medium">{t('home.import', locale)}</span>
        </a>
        <a href="/classement" class="flex flex-col items-center gap-2 card-lift rounded-2xl border bg-card p-4 text-center">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
          <span class="text-xs font-medium">{t('home.ranking', locale)}</span>
        </a>
        <a href="/categories" class="flex flex-col items-center gap-2 card-lift rounded-2xl border bg-card p-4 text-center">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
            <rect x="3" y="3" width="7" height="7" />
            <rect x="14" y="3" width="7" height="7" />
            <rect x="14" y="14" width="7" height="7" />
            <rect x="3" y="14" width="7" height="7" />
          </svg>
          <span class="text-xs font-medium">{t('search.categories', locale)}</span>
        </a>
        <a href="/additifs" class="flex flex-col items-center gap-2 card-lift rounded-2xl border bg-card p-4 text-center">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
            <path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2" />
            <path d="M8.5 2h7" />
          </svg>
          <span class="text-xs font-medium">{t('nav.additives', locale)}</span>
        </a>
      </div>
    </section>

  </main>
</Layout>
