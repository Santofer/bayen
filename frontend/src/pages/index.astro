---
// Page d'accueil Bayen (SSR — données dynamiques)
export const prerender = false

import Layout from '@/layouts/Layout.astro'
import ProductCard from '@/components/ProductCard.tsx'
import { getLocale, t } from '@/lib/i18n'

// Locale depuis le cookie SSR
const localeCookie = Astro.cookies?.get('bayen_locale')?.value ?? null
const locale = getLocale(localeCookie)

// Récupérer les produits récents et les stats depuis Directus
const DIRECTUS_URL = import.meta.env.PUBLIC_DIRECTUS_URL ?? 'https://api-bayen.n0.ma'

let recentProducts: Record<string, unknown>[] = []
let totalProducts = 0
let totalScans = 0

try {
  // Produits récents (les 6 plus scannés)
  const productsRes = await fetch(
    `${DIRECTUS_URL}/items/products?filter[status][_eq]=published&sort=-scan_count&limit=6&fields=id,barcode,name_fr,brand,image_front,scan_score,score_label,nutriscore_grade,nova_group,additives,scan_count`,
    { signal: AbortSignal.timeout(5000) }
  )
  if (productsRes.ok) {
    const data = await productsRes.json()
    recentProducts = data.data ?? []
  }

  // Nombre total de produits
  const countRes = await fetch(
    `${DIRECTUS_URL}/items/products?filter[status][_eq]=published&aggregate[count]=id`,
    { signal: AbortSignal.timeout(3000) }
  )
  if (countRes.ok) {
    const countData = await countRes.json()
    totalProducts = countData.data?.[0]?.count?.id ?? 0
  }

  // Nombre total de scans
  const scansRes = await fetch(
    `${DIRECTUS_URL}/items/scans?aggregate[count]=id`,
    { signal: AbortSignal.timeout(3000) }
  )
  if (scansRes.ok) {
    const scansData = await scansRes.json()
    totalScans = scansData.data?.[0]?.count?.id ?? 0
  }
} catch {
  // Pas de données — la page s'affiche quand même
}

// Minimum affiché pour encourager les utilisateurs
if (totalScans < 82) totalScans = 82
if (totalProducts < 12) totalProducts = 12
---

<Layout title="Bayen — Scannez. Comprenez. Choisissez mieux.">
  <main class="pb-24">

    <!-- Héro -->
    <section class="relative overflow-hidden bg-[#476a32] selection:bg-[#b1cf3a] selection:text-black">
      <!-- Grille décorative -->
      <div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff10_1px,transparent_1px),linear-gradient(to_bottom,#ffffff10_1px,transparent_1px)] bg-[size:4rem_4rem] pointer-events-none"></div>

      <div class="relative z-10 container mx-auto max-w-screen-lg px-4 pt-16 pb-20 sm:pt-24 sm:pb-28">
        <div class="flex flex-col items-center text-center relative">

          <!-- Feuille logo en arrière-plan -->
          <div class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-[0.07]">
            <img src="/logo-leaf.svg" alt="" class="w-[500px] h-[500px] sm:w-[600px] sm:h-[600px] text-white" style="filter: brightness(0) invert(1);" />
          </div>

          <!-- Texte massif -->
          <div class="relative z-10 space-y-2 sm:space-y-3">
            <h1 class="text-5xl sm:text-7xl lg:text-8xl font-black tracking-tighter text-[#f0f2d2] uppercase leading-[0.9]">
              {t('home.hero1', locale)}
            </h1>
            <h1 class="text-5xl sm:text-7xl lg:text-8xl font-black tracking-tighter text-[#b1cf3a] uppercase leading-[0.9]">
              {t('home.hero2', locale)}
            </h1>
          </div>

          <!-- Sous-titre -->
          <p class="relative z-10 mt-6 sm:mt-8 text-base sm:text-lg text-[#f0f2d2]/80 max-w-xl mx-auto leading-relaxed">
            {t('home.subtitle', locale)}
          </p>

          <!-- CTA -->
          <div class="relative z-10 flex flex-col sm:flex-row gap-3 justify-center mt-8">
            <a
              href="/scan"
              class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-full bg-[#b1cf3a] text-[#2a3f1e] text-base font-bold hover:bg-[#c4de5a] shadow-lg hover:shadow-xl transition-all"
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 7V5a2 2 0 012-2h2" />
                <path d="M17 3h2a2 2 0 012 2v2" />
                <path d="M21 17v2a2 2 0 01-2 2h-2" />
                <path d="M7 21H5a2 2 0 01-2-2v-2" />
                <line x1="7" y1="12" x2="17" y2="12" />
              </svg>
              {t('home.scanBtn', locale)}
            </a>
            <a
              href="/recherche"
              class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-full border-2 border-[#f0f2d2]/30 text-[#f0f2d2] text-base font-semibold hover:bg-[#f0f2d2]/10 transition-colors"
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8" />
                <line x1="21" y1="21" x2="16.65" y2="16.65" />
              </svg>
              {t('home.searchBtn', locale)}
            </a>
          </div>

          <!-- Badge circulaire -->
          <div dir="ltr" class="absolute -bottom-6 -right-2 sm:right-8 z-20 w-24 h-24 sm:w-28 sm:h-28 bg-[#b1cf3a] rounded-full flex items-center justify-center shadow-xl rotate-12 border-[3px] border-[#476a32]/10">
            <div class="absolute inset-0 animate-[spin_10s_linear_infinite]">
              <svg viewBox="0 0 100 100" class="w-full h-full">
                <path id="heroCirclePath" d="M 50, 50 m -35, 0 a 35,35 0 1,1 70,0 a 35,35 0 1,1 -70,0" fill="none" />
                <text class="font-bold uppercase" style={`font-size: ${locale === 'ary' ? '13px' : '10.5px'}; letter-spacing: ${locale === 'ary' ? '0.08em' : '0.14em'};`} fill="#2a3f1e">
                  <textPath href="#heroCirclePath" startOffset="0%">
                    {t('home.badge', locale)}
                  </textPath>
                </text>
              </svg>
            </div>
            <div class="absolute inset-0 flex items-center justify-center">
              <img src="/logo-leaf.svg" alt="" class="w-8 h-8 sm:w-10 sm:h-10" style="filter: brightness(0) saturate(100%) invert(15%) sepia(20%) saturate(800%) hue-rotate(65deg);" />
            </div>
          </div>

        </div>
      </div>

      <!-- Transition arrondie vers le contenu -->
      <div class="absolute bottom-0 left-0 right-0 h-8 bg-background rounded-t-[2rem]"></div>
    </section>

    <!-- Stats -->
    <section class="container mx-auto max-w-screen-lg px-4 py-2">
      <div class="grid grid-cols-3 gap-3 sm:gap-6">
        <div class="rounded-xl border bg-card p-4 text-center">
          <p class="text-2xl sm:text-3xl font-bold text-primary">
            {totalProducts.toLocaleString('fr-FR')}
          </p>
          <p class="text-xs sm:text-sm text-muted-foreground mt-1">{t('home.products', locale)}</p>
        </div>
        <div class="rounded-xl border bg-card p-4 text-center">
          <p class="text-2xl sm:text-3xl font-bold text-primary">
            {totalScans.toLocaleString('fr-FR')}
          </p>
          <p class="text-xs sm:text-sm text-muted-foreground mt-1">{t('home.scans', locale)}</p>
        </div>
        <div class="rounded-xl border bg-card p-4 text-center">
          <p class="text-2xl sm:text-3xl font-bold text-primary">100%</p>
          <p class="text-xs sm:text-sm text-muted-foreground mt-1">{t('home.free', locale)}</p>
        </div>
      </div>
    </section>

    <!-- Comment ça marche -->
    <section class="container mx-auto max-w-screen-lg px-4 py-12">
      <h2 class="text-xl font-bold text-foreground text-center mb-8">{t('home.howTitle', locale)}</h2>
      <div class="grid sm:grid-cols-3 gap-6">
        <div class="text-center">
          <div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-3">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
              <path d="M3 7V5a2 2 0 012-2h2" />
              <path d="M17 3h2a2 2 0 012 2v2" />
              <path d="M21 17v2a2 2 0 01-2 2h-2" />
              <path d="M7 21H5a2 2 0 01-2-2v-2" />
              <line x1="7" y1="12" x2="17" y2="12" />
            </svg>
          </div>
          <h3 class="font-semibold text-foreground">1. {t('home.step1', locale)}</h3>
          <p class="text-sm text-muted-foreground mt-1">
            {t('home.step1Desc', locale)}
          </p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-3">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
              <circle cx="12" cy="12" r="10" />
              <path d="M8 12l3 3 5-5" />
            </svg>
          </div>
          <h3 class="font-semibold text-foreground">2. {t('home.step2', locale)}</h3>
          <p class="text-sm text-muted-foreground mt-1">
            {t('home.step2Desc', locale)}
          </p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-3">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
              <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z" />
            </svg>
          </div>
          <h3 class="font-semibold text-foreground">3. {t('home.step3', locale)}</h3>
          <p class="text-sm text-muted-foreground mt-1">
            {t('home.step3Desc', locale)}
          </p>
        </div>
      </div>
    </section>

    <!-- Produits populaires -->
    {recentProducts.length > 0 && (
      <section class="container mx-auto max-w-screen-lg px-4 pb-12">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-xl font-bold text-foreground">{t('home.popular', locale)}</h2>
          <a href="/recherche" class="text-sm text-primary hover:underline">{t('home.seeAll', locale)}</a>
        </div>
        <div class="grid sm:grid-cols-2 gap-3">
          {recentProducts.map((product) => (
            <ProductCard product={product as any} />
          ))}
        </div>
      </section>
    )}

    <!-- CTA Contribution -->
    <section class="container mx-auto max-w-screen-lg px-4 pb-8">
      <div class="rounded-xl bg-primary/5 border border-primary/10 p-6 sm:p-8 text-center">
        <h2 class="text-lg font-bold text-foreground">{t('home.missingTitle', locale)}</h2>
        <p class="text-sm text-muted-foreground mt-2 max-w-md mx-auto">
          {t('home.missingDesc', locale)}
        </p>
        <a
          href="/contribuer"
          class="inline-flex items-center gap-2 mt-4 px-6 py-2.5 rounded-md bg-primary text-primary-foreground text-sm font-medium hover:bg-primary/90"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19" />
            <line x1="5" y1="12" x2="19" y2="12" />
          </svg>
          {t('home.addProduct', locale)}
        </a>
      </div>
    </section>

    <!-- Liens rapides -->
    <section class="container mx-auto max-w-screen-lg px-4 pb-12">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        <a href="/importer" class="flex flex-col items-center gap-2 rounded-xl border bg-card p-4 hover:shadow-md transition-shadow text-center">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
            <polyline points="7 10 12 15 17 10" />
            <line x1="12" y1="15" x2="12" y2="3" />
          </svg>
          <span class="text-xs font-medium">{t('home.import', locale)}</span>
        </a>
        <a href="/classement" class="flex flex-col items-center gap-2 rounded-xl border bg-card p-4 hover:shadow-md transition-shadow text-center">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
          <span class="text-xs font-medium">{t('home.ranking', locale)}</span>
        </a>
        <a href="/categories" class="flex flex-col items-center gap-2 rounded-xl border bg-card p-4 hover:shadow-md transition-shadow text-center">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
            <rect x="3" y="3" width="7" height="7" />
            <rect x="14" y="3" width="7" height="7" />
            <rect x="14" y="14" width="7" height="7" />
            <rect x="3" y="14" width="7" height="7" />
          </svg>
          <span class="text-xs font-medium">{t('search.categories', locale)}</span>
        </a>
        <a href="/additifs" class="flex flex-col items-center gap-2 rounded-xl border bg-card p-4 hover:shadow-md transition-shadow text-center">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
            <path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2" />
            <path d="M8.5 2h7" />
          </svg>
          <span class="text-xs font-medium">{t('nav.additives', locale)}</span>
        </a>
      </div>
    </section>

  </main>
</Layout>
