---
// Page de connexion / inscription — card centrée maquette v2
export const prerender = false
import Layout from '@/layouts/Layout.astro'
import AuthForm from '@/components/AuthForm'
import { getLocale, t } from '@/lib/i18n'

const locale = getLocale(Astro.cookies?.get('bayen_locale')?.value ?? null)
---

<Layout title="Connexion — Bayen" path="/connexion" noindex={true}>
  <main class="flex items-start justify-center px-4 py-10 sm:py-14 pb-24">
    <div class="auth-card">
      <a href="/" class="flex justify-center mb-5" aria-label="Bayen — accueil">
        <img src="/logo-bayn.svg" alt="Bayen" data-bayen-logo style="height: 38px; width: auto; filter: brightness(0) saturate(100%) invert(36%) sepia(15%) saturate(1200%) hue-rotate(65deg) brightness(92%) contrast(88%);" />
      </a>
      <h1 class="text-center text-[1.7rem] font-bold leading-tight">{t('login.welcome', locale)}</h1>
      <p class="text-center text-sm text-muted-foreground mt-1.5 mb-6">
        {t('login.subtitle', locale)}
      </p>

      <AuthForm client:load />
    </div>
  </main>
</Layout>

<style>
  /* Card centrée (maquette se-connecter v2) */
  .auth-card {
    width: 100%;
    max-width: 440px;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 28px;
    padding: 34px 30px;
    box-shadow: var(--shadow-lift);
  }
</style>
