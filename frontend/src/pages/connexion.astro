---
// Page de connexion / inscription
export const prerender = false
import Layout from '@/layouts/Layout.astro'
import AuthForm from '@/components/AuthForm'
import { getLocale, t } from '@/lib/i18n'

const locale = getLocale(Astro.cookies?.get('bayen_locale')?.value ?? null)
---

<Layout title="Connexion — Bayen">
  <main class="container mx-auto max-w-screen-lg px-4 py-12 pb-24">
    <div class="text-center mb-8">
      <h1 class="text-2xl font-bold tracking-tight">{t('login.welcome', locale)}</h1>
      <p class="text-muted-foreground mt-2">
        {t('login.subtitle', locale)}
      </p>
    </div>

    <AuthForm client:load />
  </main>
</Layout>
