---
// Page publique d'analyse de photo de repas via VLM (gemma3 vision).
// Le composant React gère tout le flux : upload → /api/meal-score → score.
export const prerender = false

import Layout from '@/layouts/Layout.astro'
import MealPhotoAnalyzer from '@/components/MealPhotoAnalyzer'
import { getLocale, t } from '@/lib/i18n'

const localeCookie = Astro.cookies?.get('bayen_locale')?.value ?? null
const locale = getLocale(localeCookie)
---

<Layout
  title={`${t('meal.pageTitle', locale)} — Bayen`}
  description={t('meal.pageSubtitle', locale)}
  path="/analyser-repas"
>
  <main class="container mx-auto max-w-screen-md px-4 pt-6 pb-24">
    <header class="mb-6 text-center space-y-2">
      <h1 class="text-3xl font-bold text-foreground">{t('meal.pageTitle', locale)}</h1>
      <p class="text-sm text-muted-foreground max-w-lg mx-auto">
        {t('meal.pageSubtitle', locale)}
      </p>
    </header>

    <MealPhotoAnalyzer client:load />
  </main>
</Layout>
