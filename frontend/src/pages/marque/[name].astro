---
// Page marque (SSR) — liste des produits d'une marque
export const prerender = false

import Layout from '@/layouts/Layout.astro'
import ProductCard from '@/components/ProductCard.tsx'
import { getLocale, t } from '@/lib/i18n'

const localeCookie = Astro.cookies?.get('bayen_locale')?.value ?? null
const locale = getLocale(localeCookie)
const { name } = Astro.params
const brandName = decodeURIComponent(name ?? '')
const DIRECTUS_URL = import.meta.env.PUBLIC_DIRECTUS_URL ?? 'https://api.bayen.ma'

let products: Record<string, unknown>[] = []
try {
  const res = await fetch(
    `${DIRECTUS_URL}/items/products?filter[brand][_icontains]=${encodeURIComponent(brandName)}&filter[status][_eq]=published&sort=-scan_count&limit=50&fields=*`
  )
  if (res.ok) {
    const data = await res.json()
    products = data.data ?? []
  }
} catch {}

const pageTitle = `${brandName} — Produits et scores Bayen`
const pageDescription = `Tous les produits de la marque ${brandName} disponibles au Maroc, leur score nutritionnel et leurs additifs.`
---

<Layout
  title={pageTitle}
  description={pageDescription}
  path={`/marque/${encodeURIComponent(name ?? '')}`}
>
  <main class="container mx-auto max-w-screen-lg px-4 py-6 pb-24">
    <h1 class="text-2xl font-bold text-foreground mb-1">{brandName}</h1>
    <p class="text-sm text-muted-foreground mb-6">
      {products.length} produit{products.length !== 1 ? 's' : ''}
    </p>

    {products.length > 0 ? (
      <div class="grid gap-3">
        {products.map((product) => (
          <ProductCard product={product as any} client:load />
        ))}
      </div>
    ) : (
      <div class="rounded-xl border bg-card p-8 text-center">
        <p class="text-sm text-muted-foreground">
          Aucun produit trouvé pour cette marque.
        </p>
        <a
          href="/scan"
          class="inline-flex items-center gap-2 mt-4 px-4 py-2 rounded-md bg-primary text-primary-foreground text-sm font-medium hover:bg-primary/90"
        >
          {t('nav.scan', locale)}
        </a>
      </div>
    )}
  </main>
</Layout>
