---
// Page journal alimentaire — utilisateur connecté.
// Auth gating côté client dans MealJournal.tsx (redirect vers /connexion si absent).
export const prerender = false

import Layout from '@/layouts/Layout.astro'
import MealJournal from '@/components/MealJournal'
import NutritionDashboard from '@/components/NutritionDashboard'
import WeeklyCoach from '@/components/WeeklyCoach'
import { getLocale, t } from '@/lib/i18n'

const localeCookie = Astro.cookies?.get('bayen_locale')?.value ?? null
const locale = getLocale(localeCookie)
---

<Layout
  title={`${t('journal.title', locale)} — Bayen`}
  description={t('journal.subtitle', locale)}
  path="/compte/journal"
  noindex={true}
>
  <main class="container mx-auto max-w-screen-lg px-4 pt-6 pb-24">
    <header class="mb-6 space-y-2">
      <h1 class="text-3xl font-bold text-foreground">{t('journal.title', locale)}</h1>
      <p class="text-sm text-muted-foreground">{t('journal.subtitle', locale)}</p>
    </header>

    <div class="mb-6 space-y-6">
      <NutritionDashboard client:load />
      <WeeklyCoach client:load />
    </div>

    <MealJournal client:load />
  </main>
</Layout>
