---
// Page liste des additifs alimentaires (SSR — fetch API à chaque requête)
export const prerender = false

import Layout from '@/layouts/Layout.astro'
import AdditivesList from '@/components/AdditivesList.tsx'
import { getLocale, t } from '@/lib/i18n'

const localeCookie = Astro.cookies?.get('bayen_locale')?.value ?? null
const locale = getLocale(localeCookie)

const DIRECTUS_URL = import.meta.env.PUBLIC_DIRECTUS_URL ?? 'https://api-bayen.n0.ma'

let additives: Record<string, unknown>[] = []

try {
  const res = await fetch(
    `${DIRECTUS_URL}/items/additives?sort=id&limit=-1&fields=id,name_fr,function,risk_level,description_fr`,
    { signal: AbortSignal.timeout(5000) }
  )
  if (res.ok) {
    const data = await res.json()
    additives = data.data ?? []
  }
} catch {
  // Page s'affiche quand même sans données
}
const RISK_COLORS: Record<string, string> = {
  safe: '#476a32',
  limited: '#f97316',
  avoid: '#ef4444',
  banned_ma: '#7f1d1d',
}

const RISK_LABEL_KEYS: Record<string, string> = {
  safe: 'additives.safe',
  limited: 'additives.limited',
  avoid: 'additives.avoid',
  banned_ma: 'additives.banned',
}

const RISK_DOT_COLORS: Record<string, string> = {
  safe: 'bg-[#476a32]',
  limited: 'bg-orange-500',
  avoid: 'bg-red-500',
  banned_ma: 'bg-red-900',
}

// Trier par risque décroissant
const RISK_ORDER = ['banned_ma', 'avoid', 'limited', 'safe']
const sortedAdditives = [...additives].sort((a: any, b: any) => {
  const rA = RISK_ORDER.indexOf(a.risk_level)
  const rB = RISK_ORDER.indexOf(b.risk_level)
  if (rA !== rB) return rA - rB
  return (a.id as string).localeCompare(b.id as string)
})
---

<Layout title="Additifs alimentaires — Bayen" description="Base de données complète des additifs alimentaires E-xxx avec niveaux de risque pour le consommateur marocain.">
  <main class="container mx-auto max-w-screen-lg px-4 py-6 pb-24">
    <div class="mb-6">
      <h1 class="text-2xl font-bold text-foreground">{t('additives.pageTitle', locale)}</h1>
      <p class="text-sm text-muted-foreground mt-1">
        {t('additives.pageDesc', locale)}
      </p>
    </div>

    {additives.length > 0 ? (
      <div>
        <!-- Composant React interactif (recherche + filtres) -->
        <div id="additives-interactive">
          <AdditivesList additives={additives as any} client:load />
        </div>
        <!-- Fallback SSR : visible si React ne charge pas -->
        <noscript>
          <div class="space-y-2">
            {sortedAdditives.map((additive: any) => (
              <a
                href={`/additifs/${additive.id}`}
                class="flex items-start gap-3 rounded-lg border bg-card p-3 hover:shadow-md transition-all"
              >
                <div class={`w-2 h-2 rounded-full mt-1.5 flex-shrink-0 ${RISK_DOT_COLORS[additive.risk_level] ?? ''}`} />
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2">
                    <span class="font-mono font-bold text-sm text-foreground">{additive.id}</span>
                    <span class="text-[10px] px-1.5 py-0.5 rounded-full text-white" style={`background-color: ${RISK_COLORS[additive.risk_level]}`}>
                      {t(RISK_LABEL_KEYS[additive.risk_level] as any, locale)}
                    </span>
                  </div>
                  <p class="text-sm text-foreground mt-0.5">{additive.name_fr}</p>
                  <p class="text-xs text-muted-foreground capitalize">{additive.function}</p>
                </div>
              </a>
            ))}
          </div>
        </noscript>
      </div>
    ) : (
      <div class="text-center py-12 rounded-xl border bg-card">
        <p class="text-muted-foreground">{t('additives.loadError', locale)}</p>
      </div>
    )}
  </main>
</Layout>
