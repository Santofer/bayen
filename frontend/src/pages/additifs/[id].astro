---
// Page fiche additif (SSR)
export const prerender = false

import Layout from '@/layouts/Layout.astro'
import { Badge } from '@/components/ui/badge.tsx'
import { getLocale, t } from '@/lib/i18n'

const locale = getLocale(Astro.cookies?.get('bayen_locale')?.value ?? null)
const { id } = Astro.params
const DIRECTUS_URL = import.meta.env.PUBLIC_DIRECTUS_URL ?? 'https://api.bayen.ma'

let additive: Record<string, unknown> | null = null
let fetchError: string | null = null

try {
  const res = await fetch(
    `${DIRECTUS_URL}/items/additives/${id}`,
    { signal: AbortSignal.timeout(5000) }
  )
  if (res.ok) {
    const data = await res.json()
    additive = data.data ?? null
  } else if (res.status === 403) {
    // Essayer sans auth (public)
    additive = null
  }
} catch {
  fetchError = 'Impossible de contacter le serveur'
}

const RISK_LABEL_KEYS: Record<string, string> = {
  safe: 'additive.risk.safe',
  limited: 'additive.risk.limited',
  avoid: 'additive.risk.avoid',
  banned_ma: 'additive.risk.banned',
}

const RISK_COLORS: Record<string, string> = {
  safe: '#476a32',
  limited: '#f97316',
  avoid: '#ef4444',
  banned_ma: '#7f1d1d',
}

const RISK_BG: Record<string, string> = {
  safe: 'bg-green-50 border-green-200',
  limited: 'bg-orange-50 border-orange-200',
  avoid: 'bg-red-50 border-red-200',
  banned_ma: 'bg-red-100 border-red-300',
}

const RISK_DESC_KEYS: Record<string, string> = {
  safe: 'additive.riskDesc.safe',
  limited: 'additive.riskDesc.limited',
  avoid: 'additive.riskDesc.avoid',
  banned_ma: 'additive.riskDesc.banned',
}

const RISK_IMPACT_KEYS: Record<string, string> = {
  safe: 'additive.impactNone',
  limited: 'additive.impactLimited',
  avoid: 'additive.impactAvoid',
  banned_ma: 'additive.impactBanned',
}

const riskLevel = (additive?.risk_level as string) ?? 'limited'
const pageTitle = additive
  ? `${id} — ${additive.name_fr} | Bayen`
  : `Additif ${id} — Bayen`
---

<Layout title={pageTitle}>
  <main class="container mx-auto max-w-screen-lg px-4 py-6 pb-24">
    <!-- Retour -->
    <a href="/additifs" class="inline-flex items-center gap-1 text-sm text-muted-foreground hover:text-foreground mb-4">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6" />
      </svg>
      {t('additive.back', locale)}
    </a>

    {fetchError && (
      <div class="rounded-xl border border-red-200 bg-red-50 p-6 text-center">
        <p class="text-red-800">{fetchError}</p>
      </div>
    )}

    {!fetchError && !additive && (
      <div class="rounded-xl border bg-card p-8 text-center">
        <h1 class="text-xl font-bold text-foreground mb-2">{t('additive.notFound', locale)} ({id})</h1>
        <p class="text-sm text-muted-foreground">{t('additive.notFoundDesc', locale)}</p>
      </div>
    )}

    {additive && (
      <div class="space-y-6">
        <!-- En-tête -->
        <div>
          <div class="flex items-center gap-3 mb-2">
            <h1 class="text-3xl font-bold font-mono text-foreground">{id}</h1>
            <div
              class="px-3 py-1 rounded-full text-sm font-semibold text-white"
              style={`background-color: ${RISK_COLORS[riskLevel]}`}
            >
              {t(RISK_LABEL_KEYS[riskLevel] as any, locale)}
            </div>
          </div>
          <h2 class="text-xl text-foreground">{(locale === 'ary' && additive.name_ar) || additive.name_fr}</h2>
          {additive.function && (
            <p class="text-sm text-muted-foreground capitalize mt-1">{(locale === 'ary' && additive.function_ar) || additive.function}</p>
          )}
        </div>

        <!-- Niveau de risque -->
        <div class={`rounded-xl border p-5 ${RISK_BG[riskLevel]}`}>
          <h3 class="text-sm font-semibold mb-2" style={`color: ${RISK_COLORS[riskLevel]}`}>
            {t(RISK_LABEL_KEYS[riskLevel] as any, locale)}
          </h3>
          <p class="text-sm text-foreground/80">
            {t(RISK_DESC_KEYS[riskLevel] as any, locale)}
          </p>
        </div>

        <!-- Description -->
        {additive.description_fr && (
          <div class="rounded-xl border bg-card p-5">
            <h3 class="text-sm font-semibold text-foreground mb-2">{t('additive.description', locale)}</h3>
            <p class="text-sm text-muted-foreground leading-relaxed">{(locale === 'ary' && additive.description_ar) || additive.description_fr}</p>
          </div>
        )}

        <!-- Sources -->
        {additive.sources && (additive.sources as string[]).length > 0 && (
          <div class="rounded-xl border bg-card p-5">
            <h3 class="text-sm font-semibold text-foreground mb-2">{t('additive.sources', locale)}</h3>
            <ul class="space-y-1">
              {(additive.sources as string[]).map((source: string) => (
                <li class="text-xs text-muted-foreground flex items-center gap-2">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="flex-shrink-0">
                    <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20" />
                  </svg>
                  {source}
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- Impact scoring -->
        <div class="rounded-xl border bg-card p-5">
          <h3 class="text-sm font-semibold text-foreground mb-2">{t('additive.scoreImpact', locale)}</h3>
          <p class="text-sm text-muted-foreground">
            {t(RISK_IMPACT_KEYS[riskLevel] as any, locale)}
          </p>
        </div>
      </div>
    )}
  </main>
</Layout>
