---
// Page détail article du blog — SSR
export const prerender = false

import Layout from '@/layouts/Layout.astro'
import BlogCard from '@/components/BlogCard.tsx'
import { getLocale, t } from '@/lib/i18n'
import type { Article, ArticleCategory } from '@/lib/types'
import { marked } from 'marked'

const locale = getLocale(Astro.cookies?.get('bayen_locale')?.value ?? null)
const { slug } = Astro.params
const DIRECTUS_URL = import.meta.env.PUBLIC_DIRECTUS_URL ?? 'https://api.bayen.ma'
const CDN_URL = import.meta.env.PUBLIC_CDN_URL ?? 'https://api.bayen.ma/assets'

// Fetch article par slug
let article: Article | null = null
try {
  const res = await fetch(
    `${DIRECTUS_URL}/items/articles?filter[slug][_eq]=${encodeURIComponent(slug ?? '')}&filter[status][_eq]=published&limit=1`,
    { signal: AbortSignal.timeout(5000) }
  )
  if (res.ok) {
    const data = await res.json()
    article = ((data.data ?? [])[0] as Article) ?? null
  }
} catch {
  // Page 404 s'affichera ci-dessous
}

// Articles similaires (même catégorie, hors article courant)
let relatedArticles: Article[] = []
if (article) {
  try {
    const url = `${DIRECTUS_URL}/items/articles?filter[status][_eq]=published&filter[category][_eq]=${article.category}&filter[id][_neq]=${article.id}&sort=-date_published&limit=3&fields=id,slug,title_fr,title_ar,excerpt_fr,excerpt_ar,cover_image,category,reading_time_min,date_published`
    const res = await fetch(url, { signal: AbortSignal.timeout(3000) })
    if (res.ok) {
      const data = await res.json()
      relatedArticles = (data.data ?? []) as Article[]
    }
  } catch {
    // non bloquant
  }
}

// Données d'affichage
const title = article
  ? (locale === 'ary' && article.title_ar) || article.title_fr
  : null
const excerpt = article
  ? (locale === 'ary' && article.excerpt_ar) || article.excerpt_fr
  : null
const contentRaw = article
  ? (locale === 'ary' && article.content_ar) || article.content_fr
  : ''

// Markdown → HTML (marked 18 safe par défaut, on ne fait pas confiance à l'input
// mais le contenu vient de l'admin Directus authentifié donc c'est OK)
let contentHtml = ''
if (contentRaw) {
  const result = marked.parse(contentRaw, { async: false, breaks: true, gfm: true })
  contentHtml = typeof result === 'string' ? result : ''
}

// Cover : image dédiée, sinon visuel de secours par catégorie (cohérent BlogCard)
const coverUrl = article?.cover_image
  ? article.cover_image.startsWith('http')
    ? article.cover_image
    : `${CDN_URL}/${article.cover_image}`
  : article
    ? `/blog/fallback-${article.category}.jpg`
    : null

const CATEGORY_LABELS_FR: Record<ArticleCategory, string> = {
  'bien-etre': 'Bien-être',
  habitudes: 'Habitudes',
  guides: 'Guides',
  actualites: 'Actualités',
}
const CATEGORY_COLORS: Record<ArticleCategory, string> = {
  'bien-etre': '#476a32',
  habitudes: '#b1cf3a',
  guides: '#0f766e',
  actualites: '#f97316',
}

// Format date (réutilise la logique de BlogCard)
const MONTHS_FR = ['janv.', 'févr.', 'mars', 'avr.', 'mai', 'juin', 'juil.', 'août', 'sept.', 'oct.', 'nov.', 'déc.']
const MONTHS_ARY = ['يناير', 'فبراير', 'مارس', 'أبريل', 'ماي', 'يونيو', 'يوليوز', 'غشت', 'شتنبر', 'أكتوبر', 'نونبر', 'دجنبر']
function formatDate(iso: string | null | undefined): string {
  if (!iso) return ''
  try {
    const d = new Date(iso)
    const months = locale === 'ary' ? MONTHS_ARY : MONTHS_FR
    return `${d.getDate()} ${months[d.getMonth()]} ${d.getFullYear()}`
  } catch { return '' }
}
const dateStr = article ? formatDate(article.date_published ?? article.date_created) : ''
const dateUpdatedStr = article?.date_updated && article.date_updated !== article.date_published
  ? formatDate(article.date_updated)
  : ''

const pageTitle = article ? `${title} — Bayen` : `${t('blog.notFound', locale)} — Bayen`
const metaDescription = excerpt ?? t('blog.description', locale)
const ogImage = coverUrl ?? undefined

// JSON-LD : BlogPosting + BreadcrumbList
const SITE_URL = 'https://bayen.ma'
const articleContentFr: string = (article?.content_fr as string | undefined) ?? ''
const wordCount = articleContentFr ? articleContentFr.split(/\s+/).filter(Boolean).length : undefined

const jsonLd = article
  ? [
      {
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: title,
        description: excerpt,
        image: coverUrl ? [coverUrl] : [`${SITE_URL}/og-default.png`],
        datePublished: article.date_published ?? article.date_created,
        dateModified: article.date_updated ?? article.date_published ?? article.date_created,
        wordCount,
        timeRequired: article.reading_time_min ? `PT${article.reading_time_min}M` : undefined,
        articleSection: CATEGORY_LABELS_FR[article.category as ArticleCategory] ?? article.category,
        inLanguage: locale === 'ary' ? 'ar-MA' : 'fr-MA',
        author: {
          '@type': 'Person',
          name: 'Amine Benboubker',
          url: 'https://aminebenboubker.com',
          image: `${SITE_URL}/avatar-amine.webp`,
          sameAs: ['https://aminebenboubker.com', 'https://www.n0.ma'],
          affiliation: { '@type': 'Organization', name: 'Bayen' },
        },
        publisher: {
          '@type': 'Organization',
          name: 'Bayen',
          logo: { '@type': 'ImageObject', url: `${SITE_URL}/icons/icon-512.png` },
        },
        mainEntityOfPage: {
          '@type': 'WebPage',
          '@id': `${SITE_URL}/blog/${article.slug}`,
        },
        url: `${SITE_URL}/blog/${article.slug}`,
      },
      {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: [
          { '@type': 'ListItem', position: 1, name: 'Accueil', item: SITE_URL },
          { '@type': 'ListItem', position: 2, name: 'Blog', item: `${SITE_URL}/blog` },
          { '@type': 'ListItem', position: 3, name: title, item: `${SITE_URL}/blog/${article.slug}` },
        ],
      },
    ]
  : undefined
---

<Layout
  title={pageTitle}
  description={metaDescription}
  path={`/blog/${slug ?? ''}`}
  ogImage={ogImage}
  ogType="article"
  jsonLd={jsonLd}
  noindex={!article}
>
  <main class="container mx-auto max-w-screen-lg px-4 py-6 pb-24 md:pb-12">
    {/* Retour */}
    <a href="/blog" class="inline-flex items-center gap-1 text-sm text-muted-foreground hover:text-foreground mb-4">
      {t('blog.back', locale)}
    </a>

    {!article ? (
      <div class="rounded-xl border bg-card p-12 text-center">
        <h1 class="text-2xl font-bold text-foreground mb-2">
          {t('blog.notFound', locale)}
        </h1>
        <p class="text-sm text-muted-foreground max-w-md mx-auto">
          {t('blog.notFoundDesc', locale)}
        </p>
      </div>
    ) : (
      <article>
        {/* Cover hero — maquette v2 : 21/9 pleine largeur, coins 26px */}
        {coverUrl && (
          <div class="mx-auto mb-2" style="max-width: 1000px">
            <div class="w-full overflow-hidden rounded-3xl bg-muted shadow-card" style="aspect-ratio: 21/10">
              <img src={coverUrl} alt={title as string} class="w-full h-full object-cover" loading="eager" />
            </div>
          </div>
        )}

        <div class="mx-auto" style="max-width: 680px">
        {/* Catégorie */}
        <span
          class="inline-block mt-6 rounded-full px-3 py-1.5 font-extrabold uppercase text-white"
          style={`background-color: ${CATEGORY_COLORS[article.category]}; font-size: 0.7rem; letter-spacing: 0.06em`}
        >
          {t(`blog.category.${article.category}` as any, locale)}
        </span>

        {/* Titre display (maquette) */}
        <h1 class="font-display text-foreground mt-3.5 mb-2.5" style="font-size: clamp(1.9rem, 3.6vw, 2.7rem); line-height: 1.06; font-weight: 780;">
          {title}
        </h1>

        {/* Méta bordée (maquette) */}
        <div class="flex flex-wrap items-center gap-3 text-muted-foreground pb-4 border-b mb-6" style="font-size: 0.83rem">
          <span>Par Amine Benboubker</span>
          {article.reading_time_min && (
            <span>· {article.reading_time_min} {t('blog.readingTimeMin', locale)}</span>
          )}
          {dateStr && <span>· {dateStr}</span>}
        </div>

        {/* Excerpt en chapeau */}
        {excerpt && (
          <p class="font-medium text-foreground leading-relaxed mb-6" style="font-size: 1.15rem">
            {excerpt}
          </p>
        )}

        {/* Contenu markdown rendu */}
        <div class="bayen-prose" set:html={contentHtml} />

        {/* Date de mise à jour si différente de la publication */}
        {dateUpdatedStr && (
          <p class="mt-8 text-xs text-muted-foreground italic">
            Mis à jour le {dateUpdatedStr}
          </p>
        )}

        {/* Bloc auteur — photo + liens (signal E-E-A-T pour Google sur les
             sujets YMYL santé/nutrition) */}
        <div class="mt-10 rounded-3xl bg-card border p-5 sm:p-6 flex gap-4 sm:gap-5 items-start shadow-card">
          <img
            src="/avatar-amine.webp"
            alt="Amine Benboubker"
            width="64"
            height="64"
            class="w-16 h-16 rounded-full object-cover flex-shrink-0 border-2 border-primary/20"
            loading="eager"
          />
          <div class="flex-1 min-w-0">
            <p class="font-display font-bold text-foreground text-lg">Amine Benboubker</p>
            <p class="text-xs text-muted-foreground mt-0.5">
              Fondateur de Bayen · Casablanca ·{' '}
              <a href="https://aminebenboubker.com" target="_blank" rel="noopener" class="text-primary font-semibold hover:underline">aminebenboubker.com</a>
              {' '}· Studio <a href="https://www.n0.ma" target="_blank" rel="noopener" class="text-primary hover:underline">N0.ma</a>
            </p>
            <p class="text-sm text-muted-foreground mt-2 leading-relaxed">
              Articles écrits avec rigueur, en citant systématiquement les sources scientifiques (OMS, EFSA, CIRC, ANSES). Algorithme de scoring public et open source.{' '}
              <a href="/methodologie" class="text-primary hover:underline">Notre méthodologie</a> · <a href="/a-propos" class="text-primary hover:underline">À propos de Bayen</a>
            </p>
          </div>
        </div>

        {/* Bas de page */}
        <div class="mt-8 pt-6 border-t">
          <a href="/blog" class="inline-flex items-center gap-1 text-sm font-medium text-primary hover:underline">
            {t('blog.back', locale)}
          </a>
        </div>

        </div>

        {/* Articles similaires */}
        {relatedArticles.length > 0 && (
          <section class="mt-16">
            <h2 class="text-xl font-bold text-foreground mb-4">
              {t('blog.related', locale)}
            </h2>
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {relatedArticles.map((related) => (
                <BlogCard article={related} locale={locale} variant="compact" />
              ))}
            </div>
          </section>
        )}
      </article>
    )}
  </main>
</Layout>

<style is:global>
  /* Styles typographiques pour le contenu markdown rendu */
  .bayen-prose {
    color: var(--color-foreground);
    line-height: 1.7;
    font-size: 1rem;
  }
  .bayen-prose > * + * { margin-top: 1em; }
  .bayen-prose h2 {
    font-size: 1.45rem;
    font-weight: 750;
    margin-top: 2em;
    margin-bottom: 0.5em;
    color: var(--color-foreground);
    line-height: 1.3;
  }
  .bayen-prose h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 1.75em;
    margin-bottom: 0.5em;
    color: var(--color-foreground);
    line-height: 1.3;
  }
  .bayen-prose h4 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-top: 1.5em;
    margin-bottom: 0.5em;
  }
  .bayen-prose p { color: var(--color-foreground); }
  .bayen-prose a {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
    font-weight: 500;
  }
  .bayen-prose a:hover { text-decoration-thickness: 2px; }
  .bayen-prose strong { font-weight: 700; color: var(--color-foreground); }
  .bayen-prose em { font-style: italic; }
  .bayen-prose ul, .bayen-prose ol {
    padding-inline-start: 1.5rem;
  }
  .bayen-prose ul { list-style-type: disc; }
  .bayen-prose ol { list-style-type: decimal; }
  .bayen-prose li { margin-top: 0.25em; }
  .bayen-prose blockquote {
    border-inline-start: 4px solid #b1cf3a;
    background: var(--color-card);
    border-radius: 0 16px 16px 0;
    padding: 18px 22px;
    margin: 24px 0;
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.5;
    color: var(--color-foreground);
    font-style: normal;
  }
  .bayen-prose code {
    background-color: var(--color-muted);
    padding: 0.15em 0.35em;
    border-radius: 0.25rem;
    font-size: 0.9em;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  }
  .bayen-prose pre {
    background-color: var(--color-muted);
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
  }
  .bayen-prose pre code {
    background: none;
    padding: 0;
  }
  .bayen-prose img {
    width: 100%;
    height: auto;
    border-radius: 0.75rem;
    margin: 1em 0;
  }
  .bayen-prose hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2em 0;
  }
</style>
