---
// Page listing du blog — SSR (données fraîches à chaque requête)
export const prerender = false

import Layout from '@/layouts/Layout.astro'
import BlogCard from '@/components/BlogCard.tsx'
import { getLocale, t } from '@/lib/i18n'
import type { Article, ArticleCategory } from '@/lib/types'

const localeCookie = Astro.cookies?.get('bayen_locale')?.value ?? null
const locale = getLocale(localeCookie)

const DIRECTUS_URL = import.meta.env.PUBLIC_DIRECTUS_URL ?? 'https://api.bayen.ma'

// Filtre catégorie optionnel via query param
const requestedCategory = Astro.url.searchParams.get('cat')
const VALID_CATEGORIES: ArticleCategory[] = ['bien-etre', 'habitudes', 'guides', 'actualites']
const selectedCategory: ArticleCategory | null = VALID_CATEGORIES.includes(requestedCategory as ArticleCategory)
  ? (requestedCategory as ArticleCategory)
  : null

// Fetch articles publiés
let articles: Article[] = []
try {
  const filterJson = selectedCategory
    ? `{"_and":[{"status":{"_eq":"published"}},{"category":{"_eq":"${selectedCategory}"}}]}`
    : `{"status":{"_eq":"published"}}`
  const url = `${DIRECTUS_URL}/items/articles?filter=${encodeURIComponent(filterJson)}&sort=-date_published&limit=60&fields=id,slug,title_fr,title_ar,excerpt_fr,excerpt_ar,cover_image,category,reading_time_min,date_published,date_created`
  const res = await fetch(url, { signal: AbortSignal.timeout(5000) })
  if (res.ok) {
    const data = await res.json()
    articles = (data.data ?? []) as Article[]
  }
} catch {
  // Page s'affiche quand même
}

// Article vedette (maquette v2) : le plus récent, en cover pleine largeur.
// Uniquement sur la vue non filtrée pour garder les listes par catégorie denses.
const CDN_URL = import.meta.env.PUBLIC_CDN_URL ?? 'https://api.bayen.ma/assets'
const FALLBACK_COVER: Record<ArticleCategory, string> = {
  'bien-etre': '/blog/fallback-bien-etre.jpg',
  habitudes: '/blog/fallback-habitudes.jpg',
  guides: '/blog/fallback-guides.jpg',
  actualites: '/blog/fallback-actualites.jpg',
}
const featured = !selectedCategory && articles.length > 0 ? articles[0] : null
const gridArticles = featured ? articles.slice(1) : articles
const featuredCover = featured
  ? (featured.cover_image
      ? (featured.cover_image.startsWith('http') ? featured.cover_image : `${CDN_URL}/${featured.cover_image}`)
      : FALLBACK_COVER[featured.category])
  : null
const featuredTitle = featured ? ((locale === 'ary' && featured.title_ar) || featured.title_fr) : null

const CATEGORIES: Array<{ value: ArticleCategory | null; labelKey: string; color: string }> = [
  { value: null,          labelKey: 'blog.allCategories',       color: '#94a3b8' },
  { value: 'bien-etre',   labelKey: 'blog.category.bien-etre',  color: '#476a32' },
  { value: 'habitudes',   labelKey: 'blog.category.habitudes',  color: '#b1cf3a' },
  { value: 'guides',      labelKey: 'blog.category.guides',     color: '#0f766e' },
  { value: 'actualites',  labelKey: 'blog.category.actualites', color: '#f97316' },
]

// JSON-LD : Blog + BreadcrumbList + ItemList (les 10 articles les plus récents)
const SITE_URL = 'https://bayen.ma'
const blogJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Blog',
    '@id': `${SITE_URL}/blog#blog`,
    url: `${SITE_URL}/blog`,
    name: 'Le blog Bayen',
    description: "Bien-être, habitudes de consommation et réflexe Bayen au Maroc.",
    inLanguage: ['fr-MA', 'ar-MA'],
    publisher: { '@id': `${SITE_URL}/#organization` },
    blogPost: articles.slice(0, 10).map((a) => ({
      '@type': 'BlogPosting',
      headline: a.title_fr,
      url: `${SITE_URL}/blog/${a.slug}`,
      datePublished: a.date_published ?? a.date_created,
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Accueil', item: SITE_URL },
      { '@type': 'ListItem', position: 2, name: 'Blog', item: `${SITE_URL}/blog` },
    ],
  },
]
---

<Layout
  title={`${t('blog.title', locale)} — Bayen`}
  description={t('blog.description', locale)}
  path="/blog"
  jsonLd={blogJsonLd}
>
  <main class="section-v2 py-6 pb-24 md:pb-12">
    {/* En-tête éditorial (maquette blog v2) */}
    <header class="mb-7">
      <p class="text-xs font-extrabold uppercase tracking-[0.08em] text-primary mb-1.5">{t('blog.kicker', locale)}</p>
      <h1 class="blog-hero-title">
        {t('blog.heroTitle1', locale)} <em>{t('blog.heroTitle2', locale)}</em>
      </h1>
      <p class="text-sm sm:text-base text-muted-foreground mt-2.5 max-w-xl">
        {t('blog.description', locale)}
      </p>
    </header>

    {/* Filtres par catégorie — pills cliquables */}
    <nav class="flex flex-wrap gap-2 mb-8" aria-label="Filtres catégories">
      {CATEGORIES.map((cat) => {
        const isActive = cat.value === selectedCategory
        const href = cat.value ? `/blog?cat=${cat.value}` : '/blog'
        return (
          <a
            href={href}
            class:list={[
              'px-3 py-1.5 rounded-full text-xs font-semibold border transition-colors',
              isActive
                ? 'text-white border-transparent'
                : 'bg-card border-border text-muted-foreground hover:text-foreground hover:border-foreground/30',
            ]}
            style={isActive ? `background-color: ${cat.color}` : undefined}
          >
            {t(cat.labelKey as any, locale)}
          </a>
        )
      })}
    </nav>

    {/* Article vedette pleine largeur (maquette v2) */}
    {featured && featuredCover && (
      <a href={`/blog/${featured.slug}`} class="blog-feature">
        <img src={featuredCover} alt={featuredTitle} loading="eager" />
        <div class="scrim">
          <span class="cat" style={`background-color: ${CATEGORIES.find(c => c.value === featured.category)?.color ?? '#b1cf3a'}`}>
            {t(`blog.category.${featured.category}` as any, locale)}
          </span>
          <h2>{featuredTitle}</h2>
          <p>
            {featured.reading_time_min ? `${featured.reading_time_min} min de lecture` : ''}
          </p>
        </div>
      </a>
    )}

    {/* Grille des articles */}
    {gridArticles.length > 0 ? (
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {gridArticles.map((article) => (
          <BlogCard article={article} locale={locale} />
        ))}
      </div>
    ) : !featured ? (
      <div class="rounded-xl border bg-card p-12 text-center text-muted-foreground">
        <p>{t('blog.empty', locale)}</p>
      </div>
    ) : null}
  </main>
</Layout>

<style>
  /* Titre éditorial (maquette blog v2) */
  .blog-hero-title {
    font-size: clamp(2rem, 4.5vw, 3.2rem) !important;
    font-weight: 780;
    line-height: 1.05;
    letter-spacing: -0.01em;
  }
  .blog-hero-title em {
    font-style: normal;
    color: hsl(97 40% 42%);
  }
  :global(.dark) .blog-hero-title em { color: #b1cf3a; }

  /* Article vedette pleine largeur */
  .blog-feature {
    position: relative;
    display: block;
    border-radius: 26px;
    overflow: hidden;
    margin-bottom: 28px;
    aspect-ratio: 21 / 10;
    min-height: 300px;
    box-shadow: var(--shadow-card);
    transition: transform 0.3s var(--ease-spring), box-shadow 0.3s var(--ease-out-soft);
  }
  .blog-feature:hover { transform: translateY(-4px); box-shadow: var(--shadow-lift); }
  .blog-feature > img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .blog-feature .scrim {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 26px 28px;
    background: linear-gradient(to top, hsl(100 35% 8% / 0.78) 0%, hsl(100 32% 12% / 0.28) 55%, transparent 100%);
  }
  .blog-feature .cat {
    align-self: flex-start;
    color: #fff;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 5px 12px;
    border-radius: 999px;
    margin-bottom: 12px;
  }
  .blog-feature h2 {
    color: #fff;
    font-size: clamp(1.4rem, 3vw, 2.2rem) !important;
    font-weight: 750;
    line-height: 1.1;
    max-width: 24ch;
    text-shadow: 0 1px 8px hsl(100 40% 6% / 0.45);
  }
  .blog-feature p {
    color: hsl(60 40% 92% / 0.8);
    font-size: 0.82rem;
    margin-top: 8px;
  }
</style>
