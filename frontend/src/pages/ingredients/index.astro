---
export const prerender = false
import Layout from '@/layouts/Layout.astro'
import { getLocale, t } from '@/lib/i18n'

const locale = getLocale(Astro.cookies?.get('bayen_locale')?.value ?? null)
const DIRECTUS_URL = import.meta.env.PUBLIC_DIRECTUS_URL ?? 'https://api-bayen.n0.ma'

interface Ingredient {
  id: number
  name_fr: string
  name_ar: string | null
  category: string
  is_allergen: boolean
  allergen_type: string | null
  icon: string
}

let ingredients: Ingredient[] = []

try {
  const res = await fetch(
    `${DIRECTUS_URL}/items/ingredients?sort=category,name_fr&limit=-1&fields=id,name_fr,name_ar,category,is_allergen,allergen_type,icon`,
    { signal: AbortSignal.timeout(5000) }
  )
  if (res.ok) {
    const data = await res.json()
    ingredients = data.data ?? []
  }
} catch {}

// Grouper par catégorie
const categories: Record<string, { label: string; items: Ingredient[] }> = {
  cereale: { label: 'Céréales', items: [] },
  sucre: { label: 'Sucres & chocolat', items: [] },
  graisse: { label: 'Huiles & graisses', items: [] },
  laitier: { label: 'Produits laitiers', items: [] },
  proteine: { label: 'Protéines & noix', items: [] },
  fruit_legume: { label: 'Fruits & légumes', items: [] },
  sel: { label: 'Sel & minéraux', items: [] },
  eau: { label: 'Eau', items: [] },
  arome: { label: 'Arômes & épices', items: [] },
  additif: { label: 'Additifs alimentaires', items: [] },
  autre: { label: 'Autres', items: [] },
}

for (const ing of ingredients) {
  const cat = categories[ing.category] ?? categories.autre
  cat.items.push(ing)
}
---

<Layout title="Base d'ingrédients — Bayen">
  <main class="container mx-auto max-w-screen-lg px-4 py-6 pb-24">
    <div class="mb-6">
      <h1 class="text-2xl font-bold tracking-tight flex items-center gap-2"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2"/><path d="M8.5 2h7"/></svg>Base d'ingrédients</h1>
      <p class="text-sm text-muted-foreground mt-1">
        {ingredients.length} ingrédients référencés. Cliquez sur un ingrédient pour voir les produits qui le contiennent.
      </p>
    </div>

    {/* Légende */}
    <div class="flex flex-wrap gap-2 mb-6">
      <span class="text-xs px-2 py-1 rounded-full bg-red-50 border border-red-200 text-red-700 inline-flex items-center gap-1"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg> Allergène</span>
      <span class="text-xs px-2 py-1 rounded-full bg-muted text-muted-foreground">Ingrédient courant</span>
    </div>

    {/* Catégories */}
    <div class="space-y-6">
      {Object.entries(categories)
        .filter(([_, cat]) => cat.items.length > 0)
        .map(([key, cat]) => (
          <div>
            <h2 class="text-sm font-bold text-foreground flex items-center gap-2 mb-3 sticky top-14 bg-background py-1 z-10">
              {cat.label}
              <span class="text-xs font-normal text-muted-foreground">({cat.items.length})</span>
            </h2>
            <div class="flex flex-wrap gap-1.5">
              {cat.items.map((ing) => (
                <a
                  href={`/ingredients/${ing.id}`}
                  class:list={[
                    'inline-flex items-center gap-1 px-2.5 py-1 rounded-lg text-xs transition-colors hover:shadow-sm',
                    ing.is_allergen
                      ? 'bg-red-50 border border-red-200 text-red-800 hover:bg-red-100'
                      : 'bg-muted text-foreground hover:bg-muted/80 border border-transparent',
                  ]}
                >
                  <span class="font-medium">{locale === 'ary' && ing.name_ar ? ing.name_ar : ing.name_fr}</span>
                  {ing.is_allergen && <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-red-500 flex-shrink-0"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>}
                </a>
              ))}
            </div>
          </div>
        ))}
    </div>
  </main>
</Layout>
