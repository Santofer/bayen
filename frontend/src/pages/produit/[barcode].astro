---
// Page fiche produit (SSR) — query Directus puis fallback Open Food Facts
export const prerender = false

import Layout from '@/layouts/Layout.astro'
import ScoreDisplay from '@/components/ScoreDisplay.tsx'
import ProductCard from '@/components/ProductCard.tsx'
import ProductActions from '@/components/ProductActions.tsx'
import OffImportButton from '@/components/OffImportButton.tsx'
import EnrichFromOff from '@/components/EnrichFromOff.tsx'
import HealthAnalysis from '@/components/HealthAnalysis.tsx'
import IngredientsList from '@/components/IngredientsList.tsx'
import { Badge } from '@/components/ui/badge.tsx'
import { computeScore, type RiskLevel } from '@/lib/scoring'
import { getLocale, t } from '@/lib/i18n'

const localeCookie = Astro.cookies?.get('bayen_locale')?.value ?? null
const locale = getLocale(localeCookie)

const { barcode } = Astro.params

const DIRECTUS_URL = import.meta.env.PUBLIC_DIRECTUS_URL ?? 'https://api-bayen.n0.ma'
const CDN_URL = import.meta.env.PUBLIC_CDN_URL ?? 'https://api-bayen.n0.ma/assets'

let scanResult: {
  found: boolean
  source?: string
  product?: Record<string, unknown>
  score?: Record<string, unknown>
  message?: string
  contribute_url?: string
} = { found: false }

let fetchError: string | null = null

// 1. Chercher dans Directus (isolé — un échec ici ne bloque pas le fallback OFF)
try {
  const directusRes = await fetch(
    `${DIRECTUS_URL}/items/products?filter[barcode][_eq]=${barcode}&filter[status][_eq]=published&limit=1&fields=*,category_id.id,category_id.name_fr,category_id.slug`
  )
  //`directus:${directusRes.status} `

  if (directusRes.ok) {
    const directusData = await directusRes.json()
    const products = directusData.data ?? []

    if (products.length > 0) {
      const p = products[0]

      // Toujours calculer le score complet (pour avoir additives_detail)
      let scoreObj: Record<string, unknown>
      {
        const additiveCodes: string[] = Array.isArray(p.additives) ? p.additives : []
        let additiveRisks: Array<{ code: string; risk_level: RiskLevel }> = []
        if (additiveCodes.length > 0) {
          try {
            const addRes = await fetch(
              `${DIRECTUS_URL}/items/additives?filter[id][_in]=${additiveCodes.join(',')}&fields=id,risk_level&limit=-1`
            )
            if (addRes.ok) {
              const addData = await addRes.json()
              const riskMap = new Map((addData.data ?? []).map((a: { id: string; risk_level: string }) => [a.id, a.risk_level]))
              additiveRisks = additiveCodes.map(code => ({
                code,
                risk_level: (riskMap.get(code) as RiskLevel) ?? 'limited',
              }))
            }
          } catch { /* fallback ci-dessous */ }
          if (additiveRisks.length === 0) {
            additiveRisks = additiveCodes.map(code => ({ code, risk_level: 'limited' as RiskLevel }))
          }
        }

        const scoreResult = computeScore({
          nutrition: {
            energy_kcal: p.energy_kcal,
            fat_saturated: p.fat_saturated,
            sugars: p.sugars,
            salt: p.salt,
            fiber: p.fiber,
            proteins: p.proteins,
          },
          novaGroup: p.nova_group as 1 | 2 | 3 | 4 | null,
          ingredientsText: p.ingredients_text,
          additives: additiveRisks,
        })
        scoreObj = scoreResult as unknown as Record<string, unknown>
      }

      // Extraire la catégorie si c'est un objet imbriqué
      const categoryObj = typeof p.category_id === 'object' && p.category_id ? p.category_id as Record<string, unknown> : null
      if (categoryObj) {
        p.category_name = categoryObj.name_fr
        p.category_slug = categoryObj.slug
        p.category_id = categoryObj.id
      }

      // Récupérer les ingrédients structurés (M2M)
      let structuredIngredients: Array<Record<string, unknown>> = []
      try {
        const piRes = await fetch(
          `${DIRECTUS_URL}/items/products_ingredients?filter[products_id][_eq]=${p.id}&fields=ingredients_id.id,ingredients_id.name_fr,ingredients_id.name_ar,ingredients_id.icon,ingredients_id.category,ingredients_id.is_allergen,ingredients_id.allergen_type,percent,rank&sort=rank&limit=-1`
        )
        if (piRes.ok) {
          const piData = await piRes.json()
          structuredIngredients = (piData.data ?? []).map((pi: Record<string, unknown>) => ({
            ...(pi.ingredients_id as Record<string, unknown>),
            percent: pi.percent,
            rank: pi.rank,
          }))
        }
      } catch { /* pas grave, fallback texte */ }

      scanResult = {
        found: true,
        source: 'directus',
        product: { ...p, structured_ingredients: structuredIngredients },
        score: scoreObj,
      }
    }
  }
} catch (e: unknown) {
  //`directus-err:${e instanceof Error ? e.message : String(e)} `
}

// 2. Fallback Open Food Facts si non trouvé dans Directus
try {
  if (!scanResult.found) {
    const offUrl = `https://world.openfoodfacts.org/api/v2/product/${barcode}.json`
    //`fetching-off `
    const offRes = await fetch(offUrl)
    //`off:${offRes.status} `

    if (offRes.ok) {
      const offData = await offRes.json()
      if (offData.status === 1 && offData.product) {
        const p = offData.product

        // Extraire les codes additifs
        const additiveCodes: string[] = (p.additives_tags || [])
          .map((t: string) => { const m = t.match(/e(\d+[a-z]?)/i); return m ? `E${m[1].toUpperCase()}` : null; })
          .filter(Boolean)

        // Récupérer les risk_level depuis Directus (les additifs sont seedés)
        let additiveRisks: Array<{ code: string; risk_level: RiskLevel }> = []
        if (additiveCodes.length > 0) {
          try {
            const addRes = await fetch(
              `${DIRECTUS_URL}/items/additives?filter[id][_in]=${additiveCodes.join(',')}&fields=id,risk_level&limit=-1`
            )
            if (addRes.ok) {
              const addData = await addRes.json()
              const riskMap = new Map((addData.data ?? []).map((a: { id: string; risk_level: string }) => [a.id, a.risk_level]))
              additiveRisks = additiveCodes.map(code => ({
                code,
                risk_level: (riskMap.get(code) as RiskLevel) ?? 'limited',
              }))
            } else {
              additiveRisks = additiveCodes.map(code => ({ code, risk_level: 'limited' as RiskLevel }))
            }
          } catch {
            additiveRisks = additiveCodes.map(code => ({ code, risk_level: 'limited' as RiskLevel }))
          }
        }

        // Données nutritionnelles
        const nutrition = {
          energy_kcal: p.nutriments?.['energy-kcal_100g'] ?? null,
          fat_saturated: p.nutriments?.['saturated-fat_100g'] ?? null,
          sugars: p.nutriments?.sugars_100g ?? null,
          salt: p.nutriments?.salt_100g ?? null,
          fiber: p.nutriments?.fiber_100g ?? null,
          proteins: p.nutriments?.proteins_100g ?? null,
        }

        // Ingrédients : prioriser le français
        const ingredientsFr = p.ingredients_text_fr
          || p.ingredients_text_with_allergens_fr
          || ''
        const ingredientsAny = p.ingredients_text || ''
        const ingredientsText = ingredientsFr || ingredientsAny
        const ingredientsLang = ingredientsFr ? 'fr' : (ingredientsAny ? 'other' : 'none')

        // Calculer le score Bayen
        const novaGroup = p.nova_group ?? null
        const scoreResult = computeScore({
          nutrition,
          novaGroup: novaGroup as 1 | 2 | 3 | 4 | null,
          ingredientsText,
          additives: additiveRisks,
        })

        scanResult = {
          found: true,
          source: 'open_food_facts',
          product: {
            barcode,
            name_fr: p.product_name_fr || p.product_name || 'Inconnu',
            brand: p.brands || 'Inconnu',
            nutriscore_grade: scoreResult.nutriscore_grade,
            nova_group: scoreResult.nova_group,
            energy_kcal: nutrition.energy_kcal,
            fat_total: p.nutriments?.fat_100g ?? null,
            fat_saturated: nutrition.fat_saturated,
            carbs_total: p.nutriments?.carbohydrates_100g ?? null,
            sugars: nutrition.sugars,
            proteins: nutrition.proteins,
            salt: nutrition.salt,
            fiber: nutrition.fiber,
            ingredients_text: ingredientsText,
            ingredients_lang: ingredientsLang,
            image_front: p.image_front_url || null,
            additives: additiveCodes,
            is_organic: !!(p.labels_tags || []).find((l: string) => l.includes('bio') || l.includes('organic')),
            is_halal: !!(p.labels_tags || []).find((l: string) => l.includes('halal')),
            scan_count: 0,
            confidence_score: scoreResult.incomplete ? 0.5 : 0.8,
          },
          score: scoreResult,
        }
      }
    }
  }
} catch (e: unknown) {
  //`off-err:${e instanceof Error ? e.message : String(e)} `
  fetchError = 'Impossible de contacter Open Food Facts'
}

const product = scanResult.product as Record<string, unknown> | undefined
const score = scanResult.score as Record<string, unknown> | undefined

// SEO
const pageTitle = product
  ? `${product.name_fr} (${product.brand}) — Score ${score?.total ?? '?'}/100 | Bayen`
  : `Produit ${barcode} — Bayen`

const pageDescription = product
  ? `${product.name_fr} de ${product.brand} : score ${score?.total ?? '?'}/100, Nutri-Score ${score?.nutriscore_grade ?? '?'}, NOVA ${score?.nova_group ?? '?'}.`
  : `Produit ${barcode} non trouvé dans la base Bayen.`

// Schema.org JSON-LD pour les fiches produit
const jsonLd = product ? {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name_fr,
  brand: { '@type': 'Brand', name: product.brand },
  ...(product.image_front ? { image: (product.image_front as string).startsWith('http') ? product.image_front : `${CDN_URL}/${product.image_front}` } : {}),
  description: pageDescription,
  sku: barcode,
  gtin13: barcode?.length === 13 ? barcode : undefined,
  nutrition: product.energy_kcal != null ? {
    '@type': 'NutritionInformation',
    calories: `${product.energy_kcal} kcal`,
    fatContent: product.fat_total != null ? `${product.fat_total} g` : undefined,
    sugarContent: product.sugars != null ? `${product.sugars} g` : undefined,
    proteinContent: product.proteins != null ? `${product.proteins} g` : undefined,
    saltContent: product.salt != null ? `${product.salt} g` : undefined,
    fiberContent: product.fiber != null ? `${product.fiber} g` : undefined,
  } : undefined,
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Score Bayen', value: score?.total ?? 'N/A' },
    { '@type': 'PropertyValue', name: 'Nutri-Score', value: score?.nutriscore_grade ?? 'N/A' },
    { '@type': 'PropertyValue', name: 'NOVA', value: score?.nova_group ?? 'N/A' },
  ],
} : undefined

const imgFront = product?.image_front as string | undefined
const ogImage = imgFront ? (imgFront.startsWith('http') ? imgFront : `${CDN_URL}/${imgFront}`) : undefined
---

<Layout title={pageTitle} description={pageDescription} path={`/produit/${barcode}`} ogType="product" ogImage={ogImage} jsonLd={jsonLd}>
  <main class="container mx-auto max-w-screen-lg px-4 py-6 pb-24">

    {/* Erreur réseau */}
    {fetchError && (
      <div class="rounded-xl border border-red-200 bg-red-50 p-6 text-center">
        <svg class="w-12 h-12 text-red-400 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
        </svg>
        <h1 class="text-lg font-semibold text-red-800 mb-1">{fetchError}</h1>
        <p class="text-sm text-red-600">{t('common.networkError', locale)}</p>
        <a href="/scan" class="inline-flex items-center gap-2 mt-4 px-4 py-2 rounded-md bg-primary text-primary-foreground text-sm font-medium hover:bg-primary/90">
          {t('nav.scan', locale)}
        </a>
      </div>
    )}

    {/* Produit non trouvé */}
    {!fetchError && !scanResult.found && (
      <div class="rounded-xl border bg-card p-8 text-center max-w-md mx-auto">
        <div class="w-16 h-16 rounded-full bg-muted flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
          </svg>
        </div>
        <h1 class="text-xl font-bold text-foreground mb-2">{t('product.notFound', locale)}</h1>
        <p class="text-sm text-muted-foreground mb-1">
          {t('product.notFoundDesc', locale)}
        </p>
        <p class="text-sm text-muted-foreground mb-6">
          {t('contribute.subtitle', locale)}
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a
            href={`/contribuer?barcode=${barcode}`}
            class="inline-flex items-center justify-center gap-2 px-6 py-2.5 rounded-md bg-primary text-primary-foreground text-sm font-medium hover:bg-primary/90"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="5" x2="12" y2="19" />
              <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
            {t('product.addThis', locale)}
          </a>
          <a
            href="/scan"
            class="inline-flex items-center justify-center gap-2 px-6 py-2.5 rounded-md border text-sm font-medium hover:bg-accent"
          >
            {t('product.scanAnother', locale)}
          </a>
        </div>
      </div>
    )}

    {/* Produit trouvé */}
    {!fetchError && scanResult.found && product && score && (
      <div class="space-y-6">
        {/* En-tête produit */}
        <div class="flex gap-4 items-start">
          {/* Image */}
          <div class="w-24 h-24 sm:w-32 sm:h-32 rounded-xl overflow-hidden bg-muted flex-shrink-0">
            {product.image_front ? (
              <img
                src={(product.image_front as string).startsWith('http') ? (product.image_front as string) : `${CDN_URL}/${product.image_front}`}
                alt={product.name_fr as string}
                class="w-full h-full object-cover"
              />
            ) : (
              <div class="w-full h-full flex items-center justify-center text-muted-foreground">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect width="18" height="18" x="3" y="3" rx="2" ry="2" />
                  <circle cx="9" cy="9" r="2" />
                  <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />
                </svg>
              </div>
            )}
          </div>

          {/* Infos */}
          <div class="flex-1 min-w-0">
            <h1 class="text-xl sm:text-2xl font-bold text-foreground">{product.name_fr}</h1>
            <div class="flex flex-wrap items-center gap-x-1 mt-0.5">
              <a href={`/marque/${encodeURIComponent((product.brand as string).split(',')[0].trim())}`} class="text-sm text-muted-foreground hover:text-primary hover:underline">
                {(product.brand as string).split(',')[0].trim()}
              </a>
              {product.category_id && (
                <span class="text-sm text-muted-foreground">·
                  <a href={`/categories/${product.category_slug ?? product.category_id}`} class="hover:text-primary hover:underline">{product.category_name ?? 'Catégorie'}</a>
                </span>
              )}
            </div>
            <div class="flex flex-wrap gap-1.5 mt-2">
              {scanResult.source === 'open_food_facts' && (
                <Badge variant="outline" className="text-xs">Open Food Facts</Badge>
              )}
              {product.is_organic && (
                <Badge variant="safe" className="text-xs">Bio</Badge>
              )}
              {product.is_halal && (
                <Badge variant="safe" className="text-xs">Halal</Badge>
              )}
            </div>
          </div>

          {/* Code-barres à droite — même hauteur que la photo */}
          <div class="hidden sm:flex flex-col items-center justify-center flex-shrink-0 w-32 h-32 rounded-xl bg-white border p-2">
            <img
              src={`https://barcodeapi.org/api/auto/${barcode}`}
              alt={barcode as string}
              class="w-full h-full object-contain"
              loading="lazy"
              onerror="this.parentElement.innerHTML='<span class=\'text-xs font-mono text-muted-foreground\'>' + this.alt + '</span>'"
            />
          </div>
        </div>
        {/* Code-barres mobile */}
        <div class="sm:hidden flex justify-center">
          <div class="flex items-center justify-center h-16 px-3 rounded-lg bg-white border">
            <img
              src={`https://barcodeapi.org/api/auto/${barcode}`}
              alt={barcode as string}
              class="h-full w-auto object-contain"
              loading="lazy"
              onerror="this.parentElement.innerHTML='<span class=\'text-xs font-mono text-muted-foreground\'>' + this.alt + '</span>'"
            />
          </div>
        </div>

        {/* Score complet */}
        <div class="rounded-xl border bg-card p-6">
          <ScoreDisplay
            score={score as any}
            confidenceScore={product.confidence_score as number | null | undefined}
            client:load
          />
        </div>

        {/* Analyse santé — commentaires explicatifs par nutriment */}
        <HealthAnalysis
          nutrition={{
            energy_kcal: product.energy_kcal as number | null,
            fat_total: product.fat_total as number | null,
            fat_saturated: product.fat_saturated as number | null,
            sugars: product.sugars as number | null,
            salt: product.salt as number | null,
            fiber: product.fiber as number | null,
            proteins: product.proteins as number | null,
          }}
          novaGroup={product.nova_group as number | null}
          nutriscoreGrade={score.nutriscore_grade as string | null}
          additives={Array.isArray(product.additives) ? product.additives as string[] : []}
          ingredients={product.ingredients_text as string ?? ''}
          client:load
        />

        {/* Données nutritionnelles */}
        {(product.energy_kcal != null || product.proteins != null) && (
          <div class="rounded-xl border bg-card p-6">
            <h2 class="text-sm font-medium text-foreground mb-4">{t('product.nutrition', locale)}</h2>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
              {[
                { label: t('product.energy', locale), value: product.energy_kcal, unit: 'kcal' },
                { label: t('product.fat', locale), value: product.fat_total, unit: 'g' },
                { label: t('product.saturatedFat', locale), value: product.fat_saturated, unit: 'g' },
                { label: t('product.carbs', locale), value: product.carbs_total, unit: 'g' },
                { label: t('product.sugars', locale), value: product.sugars, unit: 'g' },
                { label: t('product.fiber', locale), value: product.fiber, unit: 'g' },
                { label: t('product.proteins', locale), value: product.proteins, unit: 'g' },
                { label: t('product.salt', locale), value: product.salt, unit: 'g' },
              ].map((item) => (
                <div class="text-center p-2 rounded-lg bg-muted/50">
                  <p class="text-xs text-muted-foreground">{item.label}</p>
                  <p class="text-sm font-semibold text-foreground mt-0.5">
                    {item.value != null ? `${item.value} ${item.unit}` : '—'}
                  </p>
                </div>
              ))}
            </div>
          </div>
        )}

        {/* Photos nutritionnelles et ingrédients */}
        {(product.image_nutrition || product.image_ingredients) && (
          <div class="grid grid-cols-2 gap-3">
            {product.image_nutrition && (
              <div class="rounded-xl border bg-card p-3">
                <p class="text-xs font-medium text-muted-foreground mb-2"><svg class="inline w-3.5 h-3.5 mr-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M7 7h3v9H7z"/><path d="M14 7h3v5h-3z"/></svg>Tableau nutritionnel</p>
                <img
                  src={`${CDN_URL}/${product.image_nutrition}`}
                  alt="Tableau nutritionnel"
                  class="w-full rounded-lg object-contain max-h-64"
                  loading="lazy"
                />
              </div>
            )}
            {product.image_ingredients && (
              <div class="rounded-xl border bg-card p-3">
                <p class="text-xs font-medium text-muted-foreground mb-2"><svg class="inline w-3.5 h-3.5 mr-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>Liste ingrédients</p>
                <img
                  src={`${CDN_URL}/${product.image_ingredients}`}
                  alt="Liste des ingrédients"
                  class="w-full rounded-lg object-contain max-h-64"
                  loading="lazy"
                />
              </div>
            )}
          </div>
        )}

        {/* Ingrédients (structurés si disponibles, sinon fallback texte) */}
        {(product.structured_ingredients || product.ingredients_text) && (
          <IngredientsList
            ingredients={product.structured_ingredients as any[] ?? []}
            traces={Array.isArray(product.traces) ? product.traces as string[] : []}
            ingredientsText={product.ingredients_text as string ?? ''}
            locale={locale}
            client:load
          />
        )}

        {/* Confirmer / Signaler (contributeurs+) */}
        {product && (
          <div class="rounded-xl border bg-card p-4">
            <ProductActions
              productId={product.id as string}
              barcode={barcode as string}
              confidenceScore={(product.confidence_score as number) ?? 0}
              client:load
            />
          </div>
        )}

        {/* Enrichir depuis OFF (produits Directus incomplets) */}
        {scanResult.source === 'directus' && product && product.id && (
          <EnrichFromOff
            productId={product.id as string}
            barcode={barcode as string}
            existing={{
              hasImage: !!(product.image_front),
              hasNutrition: product.energy_kcal != null || product.fat_total != null,
              hasIngredients: !!(product.ingredients_text),
              hasScore: product.scan_score != null,
              hasAdditives: Array.isArray(product.additives) && (product.additives as unknown[]).length > 0,
            }}
            client:load
          />
        )}

        {/* Import depuis Open Food Facts */}
        {scanResult.source === 'open_food_facts' && product && (
          <div class="rounded-xl border border-amber-200 bg-amber-50 p-4">
            <p class="text-sm text-amber-800 mb-3">
              Ce produit provient d'Open Food Facts et n'est pas encore dans la base Bayen.
            </p>
            <OffImportButton
              barcode={barcode as string}
              productData={product}
              client:load
            />
          </div>
        )}

        {/* Actions */}
        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href={`/contribuer/${barcode}`}
            class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-md border text-sm font-medium hover:bg-accent transition-colors"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 20h9" />
