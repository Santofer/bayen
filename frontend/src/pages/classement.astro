---
export const prerender = false
import Layout from '@/layouts/Layout.astro'
import { getLocale, t } from '@/lib/i18n'

const locale = getLocale(Astro.cookies?.get('bayen_locale')?.value ?? null)
const DIRECTUS_URL = import.meta.env.PUBLIC_DIRECTUS_URL ?? 'https://api-bayen.n0.ma'

// Récupérer les top contributeurs
interface Contributor {
  id: string
  first_name: string | null
  display_name: string | null
  points: number
  contributions_count: number
  rank: string
}

let contributors: Contributor[] = []

try {
  const res = await fetch(
    `${DIRECTUS_URL}/users?fields=id,first_name,display_name,points,contributions_count,rank&filter[points][_gt]=0&sort=-points&limit=50`,
    { signal: AbortSignal.timeout(5000) }
  )
  if (res.ok) {
    const data = await res.json()
    contributors = data.data ?? []
  }
} catch {
  // pas de données
}

// Données de démo si aucun contributeur réel
if (contributors.length === 0) {
  contributors = [
    { id: 'demo-1', first_name: 'Amine', display_name: 'Amine B.', points: 340, contributions_count: 34, rank: 'expert' },
    { id: 'demo-2', first_name: 'Youssef', display_name: 'Youssef M.', points: 210, contributions_count: 18, rank: 'contributeur' },
    { id: 'demo-3', first_name: 'Fatima', display_name: 'Fatima Z.', points: 185, contributions_count: 15, rank: 'contributeur' },
    { id: 'demo-4', first_name: 'Karim', display_name: 'Karim E.', points: 120, contributions_count: 11, rank: 'contributeur' },
    { id: 'demo-5', first_name: 'Sara', display_name: 'Sara A.', points: 75, contributions_count: 7, rank: 'nouveau' },
    { id: 'demo-6', first_name: 'Omar', display_name: 'Omar H.', points: 45, contributions_count: 4, rank: 'nouveau' },
    { id: 'demo-7', first_name: 'Hajar', display_name: 'Hajar L.', points: 30, contributions_count: 3, rank: 'nouveau' },
  ]
}

const rankColors: Record<string, string> = {
  nouveau: '#a1a1aa',
  contributeur: '#b1cf3a',
  expert: '#f97316',
  'vérifié': '#476a32',
}

const rankLabelKeys: Record<string, string> = {
  nouveau: 'rank.nouveau',
  contributeur: 'rank.contributeur',
  expert: 'rank.expert',
  'vérifié': 'rank.verified',
}

const medalColors = ['text-yellow-500', 'text-gray-400', 'text-amber-600']
---

<Layout title={`${t('rank.title', locale)} — Bayen`}>
  <main class="container mx-auto max-w-screen-lg px-4 py-6 pb-24">
    <div class="text-center mb-8">
      <h1 class="text-2xl font-bold tracking-tight flex items-center justify-center gap-2"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>{t('rank.title', locale)}</h1>
      <p class="text-sm text-muted-foreground mt-2">
        {t('rank.subtitle', locale)}
      </p>
    </div>

    {contributors.length === 0 ? (
      <div class="text-center py-12">
        <p class="text-muted-foreground">{t('rank.empty', locale)}</p>
        <a href="/contribuer" class="text-primary hover:underline text-sm mt-2 inline-block">{t('rank.beFirst', locale)}</a>
      </div>
    ) : (
      <div class="space-y-2">
        {contributors.map((user, index) => {
          const name = user.display_name ?? user.first_name ?? t('rank.anonymous', locale)
          const color = rankColors[user.rank] ?? rankColors.nouveau
          const rankKey = rankLabelKeys[user.rank] ?? 'rank.nouveau'
          const rankLabel = t(rankKey as any, locale)
          const medalColor = index < 3 ? medalColors[index] : null

          return (
            <div class="flex items-center gap-3 rounded-xl border bg-card p-3 hover:shadow-sm transition-shadow">
              {/* Position */}
              <div class="w-8 text-center flex-shrink-0">
                {medalColor ? (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={medalColor}><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
                ) : (
                  <span class="text-sm font-bold text-muted-foreground">{index + 1}</span>
                )}
              </div>

              {/* Avatar */}
              <div
                class="w-10 h-10 rounded-full flex items-center justify-center text-white text-sm font-bold flex-shrink-0"
                style={`background-color: ${color}`}
              >
                {name[0].toUpperCase()}
              </div>

              {/* Infos */}
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2">
                  <p class="font-medium text-sm truncate">{name}</p>
                  <span class="text-[10px] px-1.5 py-0.5 rounded-full text-white font-medium flex-shrink-0" style={`background-color: ${color}`}>
                    {rankLabel}
                  </span>
                </div>
                <p class="text-xs text-muted-foreground">
                  {user.contributions_count} {user.contributions_count > 1 ? t('rank.contributions', locale) : t('rank.contribution', locale)}
                </p>
              </div>

              {/* Points */}
              <div class="text-right flex-shrink-0">
                <p class="text-lg font-bold text-primary">{user.points}</p>
                <p class="text-[10px] text-muted-foreground">{t('rank.pts', locale)}</p>
              </div>
            </div>
          )
        })}
      </div>
    )}

    {/* Système de points */}
    <div class="mt-10 rounded-xl border bg-card p-6">
      <h2 class="text-lg font-bold mb-4">{t('rank.howToEarn', locale)}</h2>
      <div class="grid sm:grid-cols-2 gap-3">
        {[
          { action: t('rank.addProduct', locale), points: 50 },
          { action: t('rank.addPhotos', locale), points: 20 },
          { action: t('rank.correctData', locale), points: 15 },
          { action: t('rank.scanProduct', locale), points: 1 },
          { action: t('rank.confirmedX3', locale), points: 10 },
        ].map(({ action, points }) => (
          <div class="flex items-center justify-between rounded-lg bg-muted/50 px-4 py-2.5">
            <span class="text-sm">{action}</span>
            <span class="text-sm font-bold text-primary">+{points} {t('rank.pts', locale)}</span>
          </div>
        ))}
      </div>

      <h3 class="text-sm font-bold mt-6 mb-3">{t('rank.levels', locale)}</h3>
      <div class="flex flex-wrap gap-2">
        {[
          { key: 'rank.nouveau' as const, min: 0, color: '#a1a1aa' },
          { key: 'rank.contributeur' as const, min: 100, color: '#b1cf3a' },
          { key: 'rank.expert' as const, min: 500, color: '#f97316' },
          { key: 'rank.verified' as const, min: 2000, color: '#476a32' },
        ].map(({ key, min, color }) => (
          <div class="flex items-center gap-1.5 rounded-full px-3 py-1 border text-sm">
            <div class="w-3 h-3 rounded-full" style={`background-color: ${color}`} />
            <span class="font-medium">{t(key, locale)}</span>
            <span class="text-muted-foreground text-xs">({min}+ {t('rank.pts', locale)})</span>
          </div>
        ))}
      </div>
    </div>
  </main>
</Layout>
