---
export const prerender = false

import Layout from '@/layouts/Layout.astro'
import Cart from '@/components/Cart.tsx'
import { getLocale, t } from '@/lib/i18n'

const localeCookie = Astro.cookies?.get('bayen_locale')?.value ?? null
const locale = getLocale(localeCookie)
---

<Layout
  title={`${t('cart.pageTitle', locale)} — Bayen`}
  description="Ta liste de courses Bayen : ajoute des produits, vois leur score, imprime-la ou envoie-la sur WhatsApp."
  path="/panier"
  noindex={true}
>
  <main class="container mx-auto max-w-screen-md px-4 pt-6 pb-24">
    <header class="mb-6 space-y-2">
      <h1 class="text-3xl font-bold text-foreground">{t('cart.pageTitle', locale)}</h1>
      <p class="text-sm text-muted-foreground">{t('cart.pageSubtitle', locale)}</p>
    </header>

    <Cart client:load />
  </main>
</Layout>
