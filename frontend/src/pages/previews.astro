---
/**
 * Page de prévisualisation des composants Bayen pour le blog.
 * Style shadcn/ui : fond blanc, ombre subtile, focus sur un seul composant par carte.
 *
 * Pour capturer :
 *   1. Ouvrir /previews dans Chrome
 *   2. Clic-droit sur un `.preview-block` → Inspecter
 *   3. Dans le DOM, clic-droit sur l'élément → "Capture node screenshot"
 *   → génère un PNG avec fond transparent (si on masque body bg en devtools)
 */
export const prerender = false
---

<!doctype html>
<html lang="fr" dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <title>Bayen — Component Previews</title>
    <style>
      * { box-sizing: border-box; }
      body {
        background: #fafafa;
        margin: 0;
        padding: 60px 20px;
        font-family: 'Nunito', system-ui, -apple-system, sans-serif;
        -webkit-font-smoothing: antialiased;
        color: #0a0a0a;
      }
      .preview-grid {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 80px;
        max-width: 1200px;
        margin: 0 auto;
      }
      .preview-block {
        position: relative;
      }
      .preview-label {
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #a1a1a1;
        margin-bottom: 20px;
        text-align: center;
      }
      .card {
        background: #ffffff;
        border: 1px solid #e5e5e5;
        border-radius: 16px;
      }
      /* Typographie héritée shadcn-like */
      .t-title { font-weight: 700; color: #0a0a0a; }
      .t-muted { color: #71717a; }
      .t-mono { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; }

      /* Couleurs Bayen */
      .bg-cream { background: #f3f5dc; }
      .text-primary { color: #476a32; }
      .text-lime { color: #7aa52a; }
    </style>
  </head>
  <body>
    <div class="preview-grid">

      <!-- ═══ 1. PRODUCT CARD ═══ -->
      <div class="preview-block">
        <div class="preview-label">Product Card</div>
        <div class="card" style="width: 420px; padding: 16px; display: flex; gap: 14px; align-items: center;">
          <div style="position: relative; flex-shrink: 0; width: 80px; height: 80px; border-radius: 12px; overflow: hidden; background: #f3f5dc;">
            <img src="https://images.openfoodfacts.org/images/products/611/103/500/1673/front_fr.3.400.jpg" alt="" style="width: 80px; height: 80px; object-fit: cover; display: block;" onerror="this.style.display='none'" />
            <div style="position: absolute; top: -6px; right: -6px; width: 36px; height: 36px; border-radius: 999px; background: #476a32; color: white; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 13px; box-shadow: 0 4px 10px rgba(71, 106, 50, 0.35); border: 3px solid white;">100</div>
          </div>
          <div style="flex: 1; min-width: 0;">
            <div style="font-size: 15px; font-weight: 700; color: #0a0a0a; line-height: 1.2;">Aïn Atlas</div>
            <div style="font-size: 12px; color: #71717a; margin-top: 2px;">Eau minérale naturelle · 50cl</div>
            <div style="display: flex; align-items: center; gap: 6px; margin-top: 8px;">
              <span style="display: inline-flex; align-items: center; gap: 4px; padding: 2px 8px; border-radius: 999px; background: #f0fdf4; color: #166534; font-size: 11px; font-weight: 700; border: 1px solid #bbf7d0;">
                <span style="width: 6px; height: 6px; border-radius: 999px; background: #22c55e;"></span>
                Excellent
              </span>
              <span style="padding: 2px 7px; border-radius: 6px; background: #038141; color: white; font-size: 10px; font-weight: 800; letter-spacing: 0.05em;">A</span>
              <span style="padding: 2px 7px; border-radius: 6px; background: #f3f5dc; color: #476a32; font-size: 10px; font-weight: 800;">NOVA 1</span>
            </div>
          </div>
        </div>
      </div>

      <!-- ═══ 2. SCORE GAUGE ═══ -->
      <div class="preview-block">
        <div class="preview-label">Score Gauge</div>
        <div class="card" style="width: 380px; padding: 32px; display: flex; flex-direction: column; align-items: center; gap: 20px;">
          <!-- Cercle score -->
          <div style="position: relative; width: 180px; height: 180px;">
            <svg width="180" height="180" viewBox="0 0 120 120" style="transform: rotate(-90deg);">
              <circle cx="60" cy="60" r="52" fill="none" stroke="#f4f4f5" stroke-width="10" />
              <circle cx="60" cy="60" r="52" fill="none" stroke="url(#scoreGrad)" stroke-width="10" stroke-linecap="round"
                stroke-dasharray="326.73" stroke-dashoffset="98.02" />
              <defs>
                <linearGradient id="scoreGrad" x1="0" y1="0" x2="1" y2="1">
                  <stop offset="0%" stop-color="#b1cf3a" />
                  <stop offset="100%" stop-color="#476a32" />
                </linearGradient>
              </defs>
            </svg>
            <div style="position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center;">
              <span style="font-size: 54px; font-weight: 900; color: #476a32; line-height: 1;">70</span>
              <span style="font-size: 12px; color: #a1a1aa; margin-top: 2px;">/ 100</span>
            </div>
          </div>
          <div style="text-align: center;">
            <div style="font-size: 14px; font-weight: 800; color: #476a32; letter-spacing: 0.2em; text-transform: uppercase;">Bon</div>
            <div style="font-size: 12px; color: #71717a; margin-top: 4px;">Prince Goût Chocolat · LU</div>
          </div>
          <!-- Mini breakdown -->
          <div style="width: 100%; display: flex; gap: 8px; padding-top: 16px; border-top: 1px solid #f4f4f5;">
            <div style="flex: 1; text-align: center;">
              <div style="font-size: 10px; color: #a1a1aa; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;">Nutri</div>
              <div style="font-size: 18px; font-weight: 800; color: #476a32; margin-top: 2px;">40<span style="font-size: 11px; color: #a1a1aa; font-weight: 600;">/50</span></div>
            </div>
            <div style="width: 1px; background: #f4f4f5;"></div>
            <div style="flex: 1; text-align: center;">
              <div style="font-size: 10px; color: #a1a1aa; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;">NOVA</div>
              <div style="font-size: 18px; font-weight: 800; color: #ef4444; margin-top: 2px;">10<span style="font-size: 11px; color: #a1a1aa; font-weight: 600;">/30</span></div>
            </div>
            <div style="width: 1px; background: #f4f4f5;"></div>
            <div style="flex: 1; text-align: center;">
              <div style="font-size: 10px; color: #a1a1aa; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;">Additifs</div>
              <div style="font-size: 18px; font-weight: 800; color: #476a32; margin-top: 2px;">20<span style="font-size: 11px; color: #a1a1aa; font-weight: 600;">/20</span></div>
            </div>
          </div>
        </div>
      </div>

      <!-- ═══ 3. ADDITIVES PILLS ═══ -->
      <div class="preview-block">
        <div class="preview-label">Additives</div>
        <div class="card" style="width: 440px; padding: 20px;">
