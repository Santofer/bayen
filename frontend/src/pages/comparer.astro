---
export const prerender = false

import Layout from '@/layouts/Layout.astro'
import Comparator from '@/components/Comparator.tsx'
import { getLocale, t } from '@/lib/i18n'

const localeCookie = Astro.cookies?.get('bayen_locale')?.value ?? null
const locale = getLocale(localeCookie)
---

<Layout
  title={`${t('cmp.pageTitle', locale)} — Bayen`}
  description="Compare deux produits alimentaires côte à côte : score, Nutri-Score, additifs, et un verdict clair sur lequel choisir."
  path="/comparer"
>
  <main class="container mx-auto max-w-screen-md px-4 pt-6 pb-24">
    <header class="mb-6 space-y-2 text-center">
      <h1 class="text-3xl font-bold text-foreground">{t('cmp.pageTitle', locale)}</h1>
      <p class="text-sm text-muted-foreground">{t('cmp.pageSubtitle', locale)}</p>
    </header>

    <Comparator client:load />
  </main>
</Layout>
