---
/**
 * Composant SEO — meta, OpenGraph, canonical, hreflang, JSON-LD
 * Inclus dans le Layout pour toutes les pages.
 *
 * Auto-injecte :
 *   - JSON-LD Organization + WebSite + SearchAction sur la homepage
 *   - hreflang FR + AR + x-default sur toutes les pages publiques
 *   - OG image fallback (og-default.png)
 */

interface Props {
  title: string
  description: string
  /** URL canonique (sans domaine, ex: /produit/123) */
  path?: string
  /** URL image OG (pour les previews WhatsApp/social) */
  ogImage?: string
  /** Type OG (website par défaut, article pour blog, product pour fiches) */
  ogType?: 'website' | 'article' | 'product'
  /** Données JSON-LD Schema.org additionnelles (en plus des defaults) */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[]
  /** Ne pas indexer cette page */
  noindex?: boolean
}

const {
  title,
  description,
  path = '/',
  ogImage,
  ogType = 'website',
  jsonLd,
  noindex = false,
} = Astro.props

const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? 'https://bayen.ma'
const canonicalUrl = `${siteUrl}${path}`
const ogImageUrl = ogImage ?? `${siteUrl}/og-default.png`

// ─── JSON-LD Organization + WebSite injectés automatiquement sur '/' ────
const isHomepage = path === '/' || path === ''

const organizationLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${siteUrl}/#organization`,
  name: 'Bayen',
  alternateName: 'بَيَّن',
  url: siteUrl,
  logo: {
    '@type': 'ImageObject',
    url: `${siteUrl}/logo-bayn.svg`,
    width: 600,
    height: 285,
  },
  description: 'PWA marocaine de notation des produits alimentaires. Scanner un code-barres pour comprendre la qualité nutritionnelle et les additifs.',
  foundingDate: '2026-04',
  founder: {
    '@type': 'Person',
    name: 'Amine Benboubker',
    url: 'https://www.n0.ma',
  },
  sameAs: [
    'https://github.com/Santofer/bayen',
    'https://www.n0.ma',
    'https://netspace.ma',
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer support',
    email: 'contact@n0.ma',
    availableLanguage: ['French', 'Arabic'],
  },
  areaServed: { '@type': 'Country', name: 'Morocco' },
}

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${siteUrl}/#website`,
  url: siteUrl,
  name: 'Bayen — Scannez. Comprenez. Choisissez mieux.',
  description: 'Notation participative des produits alimentaires au Maroc.',
  publisher: { '@id': `${siteUrl}/#organization` },
  inLanguage: ['fr-MA', 'ar-MA'],
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${siteUrl}/recherche?q={search_term_string}`,
    },
    'query-input': 'required name=search_term_string',
  },
}

// Concaténer les schemas : defaults + ceux passés en props
const allSchemas: Record<string, unknown>[] = []
if (isHomepage) {
  allSchemas.push(organizationLd, websiteLd)
}
if (jsonLd) {
  if (Array.isArray(jsonLd)) allSchemas.push(...jsonLd)
  else allSchemas.push(jsonLd)
}
---

<!-- Canonical -->
<link rel="canonical" href={canonicalUrl} />

<!-- Hreflang : FR + AR (le site est bilingue via cookie bayen_locale,
     les URLs sont identiques mais Google doit savoir que le contenu
     existe en 2 langues). x-default pointe vers la version FR. -->
<link rel="alternate" hreflang="fr-MA" href={canonicalUrl} />
<link rel="alternate" hreflang="ar-MA" href={canonicalUrl} />
<link rel="alternate" hreflang="x-default" href={canonicalUrl} />

<!-- OpenGraph — WhatsApp, Facebook, Twitter -->
<meta property="og:type" content={ogType} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content="Bayen — بَيَّن" />
<meta property="og:locale" content="fr_MA" />
<meta property="og:locale:alternate" content="ar_MA" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

<!-- Robots -->
{noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- JSON-LD Schema.org -->
{allSchemas.map((schema) => (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}
