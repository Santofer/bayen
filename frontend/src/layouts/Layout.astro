---
import '@/styles/globals.css'

import SeoHead from '@/components/SeoHead.astro'
import UserMenu from '@/components/UserMenu'
import LocaleToggle from '@/components/LocaleToggle'
import ThemeToggle from '@/components/ThemeToggle'
import InstallPrompt from '@/components/InstallPrompt'
import { getLocale, t } from '@/lib/i18n'

// Lire la locale depuis le cookie SSR
const localeCookie = Astro.cookies?.get('bayen_locale')?.value ?? null
const locale = getLocale(localeCookie)
const dir = locale === 'ary' ? 'rtl' : 'ltr'
const lang = locale === 'ary' ? 'ar' : 'fr'

interface Props {
  title: string
  description?: string
  /** Cacher la navigation (ex: mode scanner plein écran) */
  hideNav?: boolean
  /** URL path pour canonical (ex: /produit/123) */
  path?: string
  /** URL image OG */
  ogImage?: string
  /** Type OG */
  ogType?: 'website' | 'product'
  /** JSON-LD Schema.org */
  jsonLd?: Record<string, unknown>
  /** Ne pas indexer */
  noindex?: boolean
}

const { title, description = 'Bayen — Scannez. Comprenez. Choisissez mieux.', hideNav = false, path, ogImage, ogType, jsonLd, noindex } = Astro.props
const currentPath = Astro.url.pathname
---

<!doctype html>
<html lang={lang} dir={dir} id="html-root">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#476a32" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Mouse+Memoirs&family=Nunito:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <SeoHead title={title} description={description} path={path} ogImage={ogImage} ogType={ogType} jsonLd={jsonLd} noindex={noindex} />
    <!-- Appliquer locale + thème sauvegardés avant le premier paint -->
    <script is:inline>
      (function() {
        try {
          var l = localStorage.getItem('bayen_locale');
          if (l === 'ary') {
            document.documentElement.setAttribute('lang', 'ar');
            document.documentElement.setAttribute('dir', 'rtl');
          }
          var t = localStorage.getItem('bayen_theme');
          if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
          }
        } catch(e) {}
      })();
    </script>
  </head>
  <body class="min-h-screen bg-background font-sans antialiased overflow-x-hidden">
    {!hideNav && (
      <header class="sticky top-0 z-50 w-full border-b" data-bayen-nav>
        <div class="container flex h-14 items-center px-4 mx-auto max-w-screen-lg">
          <!-- Logo -->
          <a href="/" class="flex items-center me-6 text-primary">
            <img src="/logo-bayn.svg" alt="Bayen" class="h-8 w-auto" data-bayen-logo style="filter: brightness(0) saturate(100%) invert(36%) sepia(15%) saturate(1200%) hue-rotate(65deg) brightness(92%) contrast(88%);" />
          </a>

          <!-- Navigation desktop -->
          <nav class="hidden md:flex items-center gap-6 text-sm">
            <a
              href="/scan"
              class:list={[
                'transition-colors hover:opacity-100',
                currentPath === '/scan' ? 'font-medium' : 'opacity-60',
              ]}
            >
              {t('nav.scan', locale)}
            </a>
            <a
              href="/recherche"
              class:list={[
                'transition-colors hover:opacity-100',
                currentPath === '/recherche' ? 'font-medium' : 'opacity-60',
              ]}
            >
              {t('nav.search', locale)}
            </a>
            <a
              href="/additifs"
              class:list={[
                'transition-colors hover:opacity-100',
                currentPath.startsWith('/additifs') ? 'font-medium' : 'opacity-60',
              ]}
            >
              {t('nav.additives', locale)}
            </a>
            <a
              href="/contribuer"
              class:list={[
                'transition-colors hover:opacity-100',
                currentPath.startsWith('/contribuer') ? 'font-medium' : 'opacity-60',
              ]}
            >
              {t('nav.contribute', locale)}
            </a>
          </nav>

          <!-- Spacer -->
          <div class="flex-1" />

          <!-- Bouton scanner (mobile) -->
          <a
            href="/scan"
            class="md:hidden inline-flex items-center justify-center w-10 h-10 rounded-full bg-primary text-primary-foreground"
            aria-label="Scanner un produit"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 7V5a2 2 0 012-2h2" />
              <path d="M17 3h2a2 2 0 012 2v2" />
              <path d="M21 17v2a2 2 0 01-2 2h-2" />
              <path d="M7 21H5a2 2 0 01-2-2v-2" />
              <line x1="7" y1="12" x2="17" y2="12" />
            </svg>
          </a>

          <!-- Toggle dark/light mode -->
          <ThemeToggle client:load />

          <!-- Toggle langue FR / darija -->
          <LocaleToggle client:load />

          <!-- Menu utilisateur (connexion / profil) -->
          <UserMenu client:load />
        </div>
      </header>
    )}

    <slot />

    {!hideNav && (
      <footer class="border-t mt-12 pb-20 md:pb-0 bg-[#476a32] text-[#f0f2d2] dark:bg-[hsl(105_30%_10%)] dark:text-[hsl(63_40%_92%)]">
        <div class="container mx-auto max-w-screen-lg px-4 py-10">
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-8">
            <!-- Marque -->
            <div class="col-span-2 sm:col-span-1">
              <a href="/" class="flex items-center mb-3">
                <img src="/logo-bayn.svg" alt="Bayen" class="h-7 w-auto" data-bayen-footer-logo style="filter: brightness(0) invert(1);" />
              </a>
              <p class="text-sm opacity-70">
                {t('home.hero1', locale)}<br />{t('home.hero2', locale)}
              </p>
            </div>

            <!-- Navigation -->
            <div>
              <h3 class="font-semibold text-sm mb-3">{t('footer.navigation', locale)}</h3>
              <ul class="space-y-2 text-sm opacity-70">
                <li><a href="/scan" class="hover:opacity-100 transition-opacity">{t('nav.scan', locale)}</a></li>
                <li><a href="/recherche" class="hover:opacity-100 transition-opacity">{t('nav.search', locale)}</a></li>
                <li><a href="/additifs" class="hover:opacity-100 transition-opacity">{t('nav.additives', locale)}</a></li>
                <li><a href="/categories" class="hover:opacity-100 transition-opacity">{t('search.categories', locale)}</a></li>
              </ul>
            </div>

            <!-- Participer -->
            <div>
              <h3 class="font-semibold text-sm mb-3">{t('footer.participate', locale)}</h3>
              <ul class="space-y-2 text-sm opacity-70">
                <li><a href="/contribuer" class="hover:opacity-100 transition-opacity">{t('nav.contribute', locale)}</a></li>
                <li><a href="/importer" class="hover:opacity-100 transition-opacity">{t('home.import', locale)}</a></li>
                <li><a href="/classement" class="hover:opacity-100 transition-opacity">{t('account.rank', locale)}</a></li>
                <li><a href="/compte" class="hover:opacity-100 transition-opacity">{t('account.title', locale)}</a></li>
              </ul>
            </div>

            <!-- Infos -->
            <div>
              <h3 class="font-semibold text-sm mb-3">{t('footer.info', locale)}</h3>
              <ul class="space-y-2 text-sm opacity-70">
                <li><a href="https://www.n0.ma" target="_blank" rel="noopener noreferrer" class="hover:opacity-100 transition-opacity">N0.ma</a></li>
                <li><a href="https://netspace.ma" target="_blank" rel="noopener noreferrer" class="hover:opacity-100 transition-opacity">Netspace</a></li>
                <li><a href="mailto:contact@n0.ma" class="hover:opacity-100 transition-opacity">Contact</a></li>
              </ul>
            </div>
          </div>

          <!-- Séparateur + crédits -->
          <div class="border-t border-current/10 mt-8 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs opacity-60">
            <p>
              {t('footer.initiative', locale)}
              <a href="https://www.n0.ma" target="_blank" rel="noopener noreferrer" class="opacity-100 hover:underline font-medium">N0</a>
              &
              <a href="https://netspace.ma" target="_blank" rel="noopener noreferrer" class="opacity-100 hover:underline font-medium">Netspace</a>
            </p>
            <p>
              {t('footer.dataFrom', locale)}
              <a href="https://world.openfoodfacts.org/" target="_blank" rel="noopener noreferrer" class="opacity-100 hover:underline font-medium">Open Food Facts</a>
              (ODbL)
            </p>
          </div>
        </div>
      </footer>
    )}

    {!hideNav && (
      <!-- Navigation mobile bottom -->
      <nav class="md:hidden fixed bottom-0 left-0 right-0 z-50 border-t" data-bayen-nav style="padding-bottom: env(safe-area-inset-bottom, 8px);">
        <div class="flex items-center justify-around h-16 px-2 pb-1">
          <a href="/" class:list={['flex flex-col items-center gap-1 text-xs transition-opacity', currentPath === '/' ? 'opacity-100 font-medium' : 'opacity-50']}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
              <polyline points="9 22 9 12 15 12 15 22" />
            </svg>
            {t('nav.home', locale)}
          </a>
          <a href="/recherche" class:list={['flex flex-col items-center gap-1 text-xs transition-opacity', currentPath === '/recherche' ? 'opacity-100 font-medium' : 'opacity-50']}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8" />
              <line x1="21" y1="21" x2="16.65" y2="16.65" />
            </svg>
            {t('nav.search', locale)}
          </a>
          <a href="/scan" class="flex flex-col items-center gap-1 -mt-5">
            <div class="w-14 h-14 rounded-full flex items-center justify-center shadow-lg" data-bayen-scan-btn>
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 7V5a2 2 0 012-2h2" />
                <path d="M17 3h2a2 2 0 012 2v2" />
                <path d="M21 17v2a2 2 0 01-2 2h-2" />
                <path d="M7 21H5a2 2 0 01-2-2v-2" />
                <line x1="7" y1="12" x2="17" y2="12" />
              </svg>
            </div>
            <span class="text-xs font-medium">{t('nav.scan', locale)}</span>
          </a>
          <a href="/additifs" class:list={['flex flex-col items-center gap-1 text-xs transition-opacity', currentPath.startsWith('/additifs') ? 'opacity-100 font-medium' : 'opacity-50']}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2" />
              <path d="M8.5 2h7" />
            </svg>
            {t('nav.additives', locale)}
          </a>
          <a href="/compte" class:list={['flex flex-col items-center gap-1 text-xs transition-opacity', currentPath === '/compte' ? 'opacity-100 font-medium' : 'opacity-50']}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M19 21v-2a4 4 0 00-4-4H9a4 4 0 00-4 4v2" />
              <circle cx="12" cy="7" r="4" />
            </svg>
            {t('nav.account', locale)}
          </a>
        </div>
      </nav>
    )}

    <!-- Appliquer les couleurs navbar (inline pour éviter le tree-shaking Tailwind v4) -->
    <script is:inline>
      (function() {
        function applyNavColors() {
          var isDark = document.documentElement.classList.contains('dark');
          var bg = isDark ? '#1c3014' : '#f0f2d2';
          var fg = isDark ? '#b1cf3a' : '#476a32';
          var bc = isDark ? 'rgba(177,207,58,0.15)' : 'rgba(71,106,50,0.1)';
          var navs = document.querySelectorAll('[data-bayen-nav]');
          for (var i = 0; i < navs.length; i++) {
            navs[i].style.backgroundColor = bg;
            navs[i].style.color = fg;
            navs[i].style.borderColor = bc;
          }
          // Logo : vert foncé en light, lime en dark
          var logos = document.querySelectorAll('[data-bayen-logo]');
          var logoFilter = isDark
            ? 'brightness(0) saturate(100%) invert(81%) sepia(45%) saturate(500%) hue-rotate(30deg) brightness(105%) contrast(90%)'
            : 'brightness(0) saturate(100%) invert(36%) sepia(15%) saturate(1200%) hue-rotate(65deg) brightness(92%) contrast(88%)';
          for (var j = 0; j < logos.length; j++) {
            logos[j].style.filter = logoFilter;
          }
          // Bouton scan mobile : lime sur vert foncé en dark, vert foncé sur crème en light
          var scanBtns = document.querySelectorAll('[data-bayen-scan-btn]');
          for (var k = 0; k < scanBtns.length; k++) {
            scanBtns[k].style.backgroundColor = isDark ? '#b1cf3a' : '#476a32';
            scanBtns[k].style.color = isDark ? '#1c3014' : '#f0f2d2';
          }
          // Footer logo : crème en light (sur fond vert), lime en dark
          var footerLogos = document.querySelectorAll('[data-bayen-footer-logo]');
          var footerFilter = isDark
            ? 'brightness(0) saturate(100%) invert(81%) sepia(45%) saturate(500%) hue-rotate(30deg) brightness(105%) contrast(90%)'
            : 'brightness(0) invert(1) sepia(20%) saturate(200%) hue-rotate(20deg)';
          for (var fl = 0; fl < footerLogos.length; fl++) {
            footerLogos[fl].style.filter = footerFilter;
          }
        }
        // Appliquer au chargement
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', applyNavColors);
        } else {
          applyNavColors();
        }
        // Observer les changements de thème (classe .dark sur <html>)
        var observer = new MutationObserver(function(mutations) {
          for (var m of mutations) {
            if (m.attributeName === 'class') applyNavColors();
          }
        });
        observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
      })();
    </script>

    <!-- PWA : install prompt + service worker -->
    <InstallPrompt client:idle />
    <script is:inline>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js').catch(() => {})
      }
    </script>

    <!-- Error reporter global (fire-and-forget vers /bayen-api/log-error) -->
    <script>
      import { installGlobalErrorReporter } from '@/lib/report-error'
      installGlobalErrorReporter()
    </script>

    <style is:global>
      @keyframes scan {
        0%, 100% { top: 10%; }
        50% { top: 90%; }
      }
      .animate-scan {
        animation: scan 2s ease-in-out infinite;
      }
      /* Safe area pour la barre de navigation mobile */
      .safe-area-pb {
        padding-bottom: env(safe-area-inset-bottom, 0px);
      }
    </style>
  </body>
</html>
